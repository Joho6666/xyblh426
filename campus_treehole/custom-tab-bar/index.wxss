/* 与 app.wxss page 令牌对齐（自定义组件内需显式声明） */
.tab-bar {
  --primary: #426089;
  --primary-dim: #35547d;
  --on-primary: #f8f8ff;
  --accent: #c94a62;
  --outline-variant: #abb3b9;
  --on-surface: #2c3338;

  display: flex;
  align-items: flex-end;
  justify-content: space-around;
  height: 108rpx;
  padding-bottom: env(safe-area-inset-bottom);
  background: rgba(255, 255, 255, 0.88);
  backdrop-filter: saturate(180%) blur(20px);
  -webkit-backdrop-filter: saturate(180%) blur(20px);
  border-top: 1rpx solid rgba(116, 124, 129, 0.06);
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 999;
  box-shadow: 0 -4rpx 16rpx rgba(44, 51, 56, 0.03);
  transform: translateZ(0);
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 108rpx;
  position: relative;
  transition: transform 0.15s ease;
}
.tab-item:active {
  transform: scale(0.9);
}

.tab-center {
  justify-content: flex-start;
  padding-top: 6rpx;
}

/* ===== 中间发布按钮 ===== */
.center-btn {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: linear-gradient(145deg, var(--primary), var(--primary-dim));
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: -36rpx;
  box-shadow: 0 12rpx 32rpx rgba(66, 96, 137, 0.38);
  position: relative;
}

.center-btn:active {
  transform: scale(0.92);
  opacity: 0.9;
}

.plus-icon {
  position: relative;
  width: 40rpx;
  height: 40rpx;
}

.plus-h, .plus-v {
  position: absolute;
  background: #ffffff;
  border-radius: 4rpx;
}

.plus-h {
  width: 40rpx;
  height: 6rpx;
  top: 17rpx;
  left: 0;
}

.plus-v {
  width: 6rpx;
  height: 40rpx;
  left: 17rpx;
  top: 0;
}

/* ===== 图标区域 ===== */
.icon-wrap {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 4rpx;
}

.svg-icon {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.tab-badge {
  position: absolute;
  top: -10rpx;
  right: -16rpx;
  min-width: 32rpx;
  height: 32rpx;
  padding: 0 8rpx;
  border-radius: 999rpx;
  background: var(--accent);
  color: #ffffff;
  font-size: 18rpx;
  font-weight: 700;
  line-height: 32rpx;
  text-align: center;
  box-sizing: border-box;
}

/* ===== Tab文字 ===== */
.tab-text {
  font-size: 20rpx;
  color: var(--outline-variant);
  font-weight: 500;
  line-height: 1;
}

.tab-text.active {
  color: var(--primary);
  font-weight: 700;
}
.svg-icon.active {
  transition: transform 0.2s ease;
  transform: scale(1.08);
}

/* ===== CSS图标 ===== */

/* 首页 - 空心小屋 */
.icon-home {
  width: 44rpx; height: 44rpx;
  border: 4rpx solid var(--outline-variant);
  border-top: none;
  border-radius: 0 0 8rpx 8rpx;
  position: relative;
  margin-top: 14rpx;
}
.icon-home::before {
  content: '';
  position: absolute;
  top: -16rpx; left: 50%;
  transform: translateX(-50%);
  width: 0; height: 0;
  border-left: 28rpx solid transparent;
  border-right: 28rpx solid transparent;
  border-bottom: 18rpx solid var(--outline-variant);
}

/* 首页 - 实心 */
.icon-home-fill {
  width: 44rpx; height: 44rpx;
  background: var(--primary);
  border-radius: 0 0 8rpx 8rpx;
  position: relative;
  margin-top: 14rpx;
}
.icon-home-fill::before {
  content: '';
  position: absolute;
  top: -16rpx; left: 50%;
  transform: translateX(-50%);
  width: 0; height: 0;
  border-left: 28rpx solid transparent;
  border-right: 28rpx solid transparent;
  border-bottom: 18rpx solid var(--primary);
}

/* 集市 - 购物袋空心 */
.icon-market {
  width: 36rpx; height: 38rpx;
  border: 4rpx solid var(--outline-variant);
  border-radius: 0 0 10rpx 10rpx;
  position: relative;
  margin-top: 10rpx;
}
.icon-market::before {
  content: '';
  position: absolute;
  top: -14rpx; left: 50%;
  transform: translateX(-50%);
  width: 20rpx; height: 14rpx;
  border: 4rpx solid var(--outline-variant);
  border-bottom: none;
  border-radius: 12rpx 12rpx 0 0;
}

/* 集市 - 购物袋实心 */
.icon-market-fill {
  width: 36rpx; height: 38rpx;
  background: var(--primary);
  border-radius: 0 0 10rpx 10rpx;
  position: relative;
  margin-top: 10rpx;
}
.icon-market-fill::before {
  content: '';
  position: absolute;
  top: -14rpx; left: 50%;
  transform: translateX(-50%);
  width: 20rpx; height: 14rpx;
  border: 4rpx solid var(--primary);
  border-bottom: none;
  border-radius: 12rpx 12rpx 0 0;
}

/* 消息 - 气泡空心 */
.icon-message {
  width: 44rpx; height: 36rpx;
  border: 4rpx solid var(--outline-variant);
  border-radius: 18rpx 18rpx 18rpx 4rpx;
  position: relative;
}

/* 消息 - 气泡实心 */
.icon-message-fill {
  width: 44rpx; height: 36rpx;
  background: var(--primary);
  border-radius: 18rpx 18rpx 18rpx 4rpx;
}

/* 我 - 头像空心 */
.icon-mine {
  width: 20rpx; height: 20rpx;
  border: 4rpx solid var(--outline-variant);
  border-radius: 50%;
  position: relative;
  margin-top: -4rpx;
}
.icon-mine::after {
  content: '';
  position: absolute;
  bottom: -20rpx; left: 50%;
  transform: translateX(-50%);
  width: 36rpx; height: 20rpx;
  border: 4rpx solid var(--outline-variant);
  border-bottom: none;
  border-radius: 18rpx 18rpx 0 0;
}

/* 我 - 头像实心 */
.icon-mine-fill {
  width: 20rpx; height: 20rpx;
  background: var(--primary);
  border-radius: 50%;
  position: relative;
  margin-top: -4rpx;
}
.icon-mine-fill::after {
  content: '';
  position: absolute;
  bottom: -20rpx; left: 50%;
  transform: translateX(-50%);
  width: 36rpx; height: 20rpx;
  background: var(--primary);
  border-radius: 18rpx 18rpx 0 0;
}
