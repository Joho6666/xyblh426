@import '../admin-announcement/admin-announcement.wxss';

.act-status {
  margin: 16rpx 0 24rpx;
  padding: 20rpx 24rpx;
  background: #e8f5e9;
  border-radius: 16rpx;
}

.act-status--muted {
  background: #f5f5f5;
}

.act-status-line {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #1b5e20;
}

.act-status--muted .act-status-line {
  color: #5b6b7a;
  font-weight: 500;
}

.act-status-sub {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #5b6b7a;
}

.end-at-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.end-at-picker {
  padding: 16rpx 24rpx;
  background: #f0f4f8;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #1f2b3d;
}

.end-at-clear {
  font-size: 26rpx;
  color: #1565c0;
  padding: 12rpx;
}

.btn-secondary {
  margin-top: 20rpx;
  background: #fff;
  color: #1565c0;
  border: 2rpx solid #1565c0;
}

.btn-danger {
  margin-top: 20rpx;
  background: #ffebee;
  color: #c62828;
}

/* 轮播卡片：避免与全局 .h1 叠加大间距 */
.slide-block {
  overflow: visible;
}

.slide-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.slide-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1f2b3d;
}

.slide-del {
  font-size: 26rpx;
  color: #c62828;
  font-weight: 600;
  padding: 8rpx 12rpx;
}

.slide-uploading {
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #5b6b7a;
}

.slide-fields {
  display: flex;
  flex-direction: column;
  gap: 0;
}

/* 小程序 input 必须给足高度，否则会被压成细条 */
.act-input {
  display: block;
  width: 100%;
  box-sizing: border-box;
  min-height: 96rpx;
  height: 96rpx;
  line-height: 44rpx;
  padding: 24rpx 22rpx;
  margin-bottom: 20rpx;
  background: #f6f7fb;
  border-radius: 16rpx;
  border: 1rpx solid #e5e9f0;
  font-size: 28rpx;
  color: #243245;
}

.act-input--last {
  margin-bottom: 0;
}

/* textarea：固定最小高度 + auto-height 可增高 */
.act-textarea {
  display: block;
  width: 100%;
  box-sizing: border-box;
  min-height: 200rpx;
  padding: 22rpx;
  margin-bottom: 20rpx;
  background: #f6f7fb;
  border-radius: 16rpx;
  border: 1rpx solid #e5e9f0;
  font-size: 28rpx;
  color: #243245;
  line-height: 1.6;
}

.act-textarea--lg {
  min-height: 260rpx;
}

.slide-preview {
  width: 100%;
  height: 220rpx;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
  background: #e8edf5;
}

.slide-img {
  width: 100%;
  height: 100%;
}

.add-slide {
  text-align: center;
  padding: 24rpx;
  border-radius: 16rpx;
  border: 2rpx dashed #426089;
  color: #426089;
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
  box-sizing: border-box;
}
