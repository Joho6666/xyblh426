.page {
  min-height: 100vh;
  padding: 24rpx;
  padding-bottom: 48rpx;
  background: #f7f9fc;
  box-sizing: border-box;
}

.toolbar {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.btn-add {
  margin: 0;
}

.toolbar-hint {
  font-size: 24rpx;
  color: #888;
  flex: 1;
  min-width: 200rpx;
}

.form-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(66, 96, 137, 0.1);
  border: 1rpx solid #e0e8f0;
}

.form-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 20rpx;
}

.form-row {
  display: flex;
  align-items: center;
  margin-bottom: 18rpx;
}

.form-label {
  width: 160rpx;
  font-size: 28rpx;
  color: #666;
  flex-shrink: 0;
}

.form-input {
  flex: 1;
  font-size: 28rpx;
  padding: 12rpx 16rpx;
  background: #f5f7fa;
  border-radius: 8rpx;
}

.picker-row .picker-val {
  flex: 1;
  font-size: 28rpx;
  padding: 12rpx 16rpx;
  background: #f5f7fa;
  border-radius: 8rpx;
  color: #333;
}

.form-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 12rpx;
}

.form-btn {
  margin: 0;
}

.tip {
  padding: 24rpx;
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
}

.loading {
  text-align: center;
  padding: 48rpx;
  color: #999;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(66, 96, 137, 0.08);
}

.row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 28rpx;
  padding: 10rpx 0;
}

.title-row {
  border-bottom: 1rpx solid #eee;
  margin-bottom: 8rpx;
  padding-bottom: 16rpx;
}

.name {
  font-weight: 600;
  font-size: 32rpx;
  color: #1a1a1a;
}

.badge {
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
  background: #e8f0f8;
  color: #426089;
}

.k {
  color: #888;
}

.v {
  color: #333;
  max-width: 460rpx;
  text-align: right;
  word-break: break-all;
}

.stats {
  justify-content: flex-start;
  gap: 8rpx;
  color: #555;
  margin-top: 8rpx;
}

.num {
  font-weight: 600;
  color: #426089;
}

.sep {
  color: #ccc;
  margin: 0 8rpx;
}

.qr-wrap {
  margin-top: 20rpx;
  text-align: center;
}

.qr {
  width: 280rpx;
  height: 280rpx;
  background: #fafafa;
}

.qr-missing {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #999;
}

.card-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 20rpx;
}

.btn-edit,
.btn-gen {
  margin: 0;
  flex: 1;
  min-width: 200rpx;
}
