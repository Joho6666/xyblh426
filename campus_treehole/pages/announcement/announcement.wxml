<view class="page">
  <view class="header">
    <text class="title">校区公告</text>
    <text class="sub">仅展示当前校区及全局公告</text>
  </view>

  <view class="empty" wx:if="{{!loading && list.length === 0}}">
    <text>暂无公告</text>
  </view>

  <view class="list" wx:else>
    <view class="card" wx:for="{{list}}" wx:key="_id" bindtap="onTapItem" data-id="{{item._id}}">
      <view class="row">
        <text class="card-title">{{item.title}}</text>
        <text class="badge {{item.priority === 'urgent' ? 'urgent' : item.priority === 'important' ? 'important' : ''}}">
          {{item.priority === 'urgent' ? '紧急' : item.priority === 'important' ? '重要' : '普通'}}
        </text>
      </view>
      <image class="cover" wx:if="{{item.images && item.images.length}}" src="{{item.images[0]}}" mode="widthFix"></image>
      <text class="content">{{item.content}}</text>
      <view class="meta">
        <text>{{item.publishAt ? item.publishAt : item.createTime}}</text>
        <text>{{item._readMarked ? '已读' : '未读'}}</text>
      </view>
    </view>
  </view>

  <view class="loading" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>
</view>
