.page {
  padding: 24rpx;
}

.header {
  margin-bottom: 20rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
}

.sub {
  display: block;
  margin-top: 8rpx;
  color: #7a7f89;
  font-size: 24rpx;
}

.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
}

.row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  flex: 1;
  margin-right: 16rpx;
}

.badge {
  font-size: 20rpx;
  color: #426089;
  background: #e8eef9;
  border-radius: 999rpx;
  padding: 4rpx 12rpx;
}

.badge.important {
  color: #a35b00;
  background: #fff3df;
}

.badge.urgent {
  color: #b42318;
  background: #fee4e2;
}

.content {
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #3d4148;
  line-height: 1.6;
}

.cover {
  width: 100%;
  height: auto;
  border-radius: 12rpx;
  margin-top: 12rpx;
  background: #f5f7fb;
}

.meta {
  margin-top: 12rpx;
  display: flex;
  justify-content: space-between;
  font-size: 22rpx;
  color: #9aa0a8;
}

.empty,
.loading {
  text-align: center;
  color: #8a9099;
  padding: 120rpx 0;
}
