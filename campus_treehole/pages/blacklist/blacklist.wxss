.page-container {
  padding: 20rpx 28rpx;
  min-height: 100vh;
  background: var(--surface-container-low, #f7f9fc);
}

.hint-bar {
  padding: 16rpx 20rpx;
  margin-bottom: 20rpx;
  background: var(--surface-container-lowest, #fff);
  border-radius: var(--radius-m, 16rpx);
  font-size: 24rpx;
  color: var(--on-surface-variant, #555);
  line-height: 1.5;
}

.empty-state {
  padding: 120rpx 40rpx;
  text-align: center;
}
.empty-icon {
  font-size: 64rpx;
  display: block;
  margin-bottom: 16rpx;
}
.empty-text {
  font-size: 28rpx;
  color: var(--outline-variant, #888);
}

.user-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.user-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  background: var(--surface-container-lowest, #fff);
  border-radius: var(--radius-m, 16rpx);
}

.user-card-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1;
  min-width: 0;
}

.user-card-avatar {
  width: 84rpx;
  height: 84rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.user-card-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  min-width: 0;
}

.user-card-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--on-surface, #1f1f1f);
}

.user-card-college {
  font-size: 22rpx;
  color: var(--outline-variant, #888);
}

.btn-unblock {
  flex-shrink: 0;
  padding: 14rpx 28rpx;
  border-radius: 999rpx;
  background: var(--surface-container-low, #eef1f5);
  border: 2rpx solid var(--outline-variant, #ccc);
  font-size: 26rpx;
  font-weight: 600;
  color: var(--primary, #426089);
}

.load-status {
  padding: 40rpx;
  text-align: center;
}
.load-text {
  font-size: 24rpx;
  color: var(--outline-variant, #888);
}
