.chat-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: var(--surface);
}

.chat-user-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 28rpx;
  background: rgba(255, 255, 255, 0.94);
  backdrop-filter: blur(12px);
  border-bottom: 1rpx solid var(--hairline);
  box-shadow: 0 4rpx 20rpx rgba(44, 51, 56, 0.04);
}

.chat-user-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
}

.chat-user-name {
  flex: 1;
  font-size: 28rpx;
  font-weight: 700;
  color: var(--on-surface);
}

.chat-user-tip {
  font-size: 22rpx;
  color: var(--outline-variant);
}

.chat-status-bar {
  padding: 14rpx 28rpx;
  background: var(--success-container);
  color: var(--on-success-container);
  font-size: var(--text-xs);
  font-weight: 600;
}

.chat-body {
  flex: 1;
  overflow: hidden;
}

.chat-empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  padding: 80rpx 24rpx 24rpx;
  text-align: center;
}

.chat-empty-icon {
  font-size: 72rpx;
}

.chat-empty-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--on-surface);
}

.chat-empty-sub {
  font-size: 24rpx;
  color: var(--outline-variant);
}

.chat-retry-btn {
  margin-top: 12rpx;
  padding: 18rpx 36rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, var(--primary), var(--primary-dim));
  color: var(--on-primary);
  font-size: var(--text-sm);
  font-weight: 700;
  box-shadow: 0 8rpx 24rpx rgba(66, 96, 137, 0.22);
}

.chat-msg-list {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
  padding: 24rpx 24rpx 18rpx;
}

.chat-msg {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
}

.chat-msg-mine {
  flex-direction: row-reverse;
}

.chat-msg-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.chat-msg-main {
  display: flex;
  flex-direction: column;
  max-width: calc(100% - 110rpx);
}

.chat-msg-mine .chat-msg-main {
  align-items: flex-end;
}

.chat-msg-other .chat-msg-main {
  align-items: flex-start;
}

.chat-time {
  margin-bottom: 8rpx;
  font-size: 22rpx;
  color: var(--outline-variant);
}

.chat-bubble {
  max-width: 100%;
  padding: 20rpx 24rpx;
  border-radius: 24rpx;
  font-size: 30rpx;
  line-height: 1.55;
  word-break: break-word;
}

.bubble-other {
  background: var(--surface-container-lowest);
  color: var(--on-surface);
  border-top-left-radius: 8rpx;
}

.bubble-mine {
  background: linear-gradient(135deg, var(--primary), var(--primary-dim));
  color: var(--on-primary);
  border-top-right-radius: 8rpx;
}

.chat-text {
  font-size: 30rpx;
}

.chat-emoji-text {
  font-size: 44rpx;
  line-height: 1;
}

.image-bubble {
  overflow: hidden;
  border-radius: 24rpx;
}

.image-bubble-mine {
  border-top-right-radius: 8rpx;
}

.image-bubble-other {
  border-top-left-radius: 8rpx;
}

.chat-image {
  display: block;
  width: 320rpx;
  max-width: 100%;
  border-radius: 24rpx;
}

.voice-bubble {
  min-width: 132rpx;
  padding: 18rpx 22rpx;
  border-radius: 24rpx;
}

.voice-bubble-mine {
  background: #95ef63;
  border-top-right-radius: 8rpx;
}

.voice-bubble-other {
  background: var(--surface-container-lowest);
  border-top-left-radius: 8rpx;
}

.voice-bubble-playing {
  box-shadow: 0 0 0 4rpx rgba(149, 239, 99, 0.18);
}

.voice-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.voice-content-mine {
  flex-direction: row-reverse;
}

.voice-content-other {
  flex-direction: row;
}

.voice-wave {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--on-surface);
  letter-spacing: -4rpx;
}

.voice-duration {
  font-size: 42rpx;
  line-height: 1;
  color: var(--on-surface);
}

.share-card {
  width: 420rpx;
  border-radius: 24rpx;
  overflow: hidden;
  background: var(--surface-container-lowest);
  box-shadow: 0 10rpx 26rpx rgba(15, 23, 42, 0.08);
}

.share-card-mine {
  background: var(--surface-container-low);
}

.share-card-cover {
  width: 100%;
  height: 220rpx;
  display: block;
}

.share-card-content {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  padding: 18rpx 20rpx 20rpx;
}

.share-card-tag,
.pending-share-tag {
  font-size: 20rpx;
  color: var(--primary);
  font-weight: 700;
}

.share-card-title,
.pending-share-title {
  font-size: 28rpx;
  color: var(--on-surface);
  font-weight: 700;
  line-height: 1.4;
}

.share-card-sub,
.pending-share-sub {
  font-size: 22rpx;
  color: var(--on-surface-variant);
}

.recording-overlay {
  position: fixed;
  inset: 0;
  z-index: 9999;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: rgba(15, 23, 42, 0.45);
}

.recording-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
  padding: 52rpx 56rpx 44rpx;
  border-radius: 24rpx;
  background: rgba(30, 41, 59, 0.92);
  box-shadow: 0 24rpx 80rpx rgba(0, 0, 0, 0.35);
  min-width: 400rpx;
}

.recording-box.recording-box-cancel {
  background: rgba(127, 29, 29, 0.94);
}

.recording-mic-wrap {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
}

.recording-cancel-icon {
  font-size: 64rpx;
  color: #fecaca;
  font-weight: 300;
  line-height: 1;
}

.recording-indicator {
  width: 100%;
}

.recording-waves {
  display: flex;
  align-items: flex-end;
  justify-content: center;
  gap: 10rpx;
  height: 128rpx;
  padding: 0 8rpx;
}

.recording-wave-bar {
  width: 14rpx;
  min-height: 20rpx;
  background: linear-gradient(180deg, var(--primary-container) 0%, var(--primary) 48%, var(--primary-dim) 100%);
  border-radius: 7rpx;
  box-shadow: 0 0 12rpx rgba(34, 211, 238, 0.35);
}

.recording-timer {
  font-size: 52rpx;
  font-weight: 700;
  font-variant-numeric: tabular-nums;
  color: #f8fafc;
  letter-spacing: 4rpx;
}

.recording-hint,
.recording-cancel-text {
  font-size: 26rpx;
  color: rgba(248, 250, 252, 0.88);
}

.recording-cancel-text {
  color: #fecaca;
}

.recording-bottom-hint {
  margin-top: 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  font-size: 26rpx;
  color: rgba(248, 250, 252, 0.85);
}

.recording-bottom-hint-cancel {
  color: #fecaca;
}

.recording-arrow {
  font-size: 40rpx;
  line-height: 1;
  opacity: 0.9;
}

.pending-share {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 18rpx;
  background: var(--surface-container-lowest);
  border-top: 1rpx solid rgba(148, 163, 184, 0.14);
}

.pending-share-card {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 16rpx;
  min-width: 0;
  padding: 16rpx;
  border-radius: 22rpx;
  background: var(--surface-container-low);
}

.pending-share-cover {
  width: 92rpx;
  height: 92rpx;
  border-radius: 18rpx;
  flex-shrink: 0;
}

.pending-share-main {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.pending-share-send {
  padding: 18rpx 28rpx;
  border-radius: 999rpx;
  background: var(--primary);
  color: #fff;
  font-size: 24rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.chat-input-bar {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 18rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: var(--surface-container-lowest);
  border-top: 1rpx solid rgba(148, 163, 184, 0.18);
}

.tool-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: var(--surface-container);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  color: var(--secondary);
  flex-shrink: 0;
}

.tool-btn-mode {
  width: 76rpx;
  height: 68rpx;
  border-radius: 16rpx;
  flex-direction: column;
  gap: 2rpx;
  padding: 6rpx 4rpx;
}

.tool-mode-emoji {
  font-size: 28rpx;
  line-height: 1;
}

.tool-mode-label {
  font-size: 18rpx;
  color: var(--on-surface-variant);
  font-weight: 600;
  line-height: 1;
}

.voice-hold-btn {
  flex: 1;
  min-height: 80rpx;
  max-height: 88rpx;
  margin: 0 6rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #ededed;
  border-radius: 16rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.06);
}

.voice-hold-text {
  font-size: 30rpx;
  color: var(--on-surface);
  font-weight: 600;
  text-align: center;
  line-height: 1.35;
}

.voice-hold-btn-active {
  background: #d1d1d1;
}

.voice-hold-btn-hover {
  background: #e2e2e2;
}

.chat-input {
  flex: 1;
  height: 68rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  background: #f8fafc;
  font-size: 28rpx;
  color: var(--on-surface);
}

.chat-send-btn {
  padding: 0 28rpx;
  height: 68rpx;
  border-radius: 999rpx;
  background: var(--primary);
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.chat-send-btn-disabled {
  opacity: 0.45;
}

.action-panel {
  display: flex;
  gap: 26rpx;
  padding: 24rpx 24rpx calc(24rpx + env(safe-area-inset-bottom));
  background: var(--surface-container-lowest);
  border-top: 1rpx solid rgba(148, 163, 184, 0.14);
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.action-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 28rpx;
  background: #f8fafc;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 42rpx;
}

.action-label {
  font-size: 24rpx;
  color: var(--secondary);
}

.emoji-panel {
  background: var(--surface-container-lowest);
  padding: 18rpx 18rpx calc(18rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid rgba(148, 163, 184, 0.14);
}

.emoji-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 6rpx;
}

.emoji-item {
  width: calc(100% / 8 - 6rpx);
  padding: 14rpx 0;
  border-radius: 16rpx;
  text-align: center;
  font-size: 42rpx;
}

.emoji-item:active {
  background: #f8fafc;
}

.tool-btn-recording {
  background: #ffe7df;
  color: #cf5a3a;
}
