.contact-page {
  min-height: 100vh;
  background: #f6f7fb;
  padding: 24rpx;
  box-sizing: border-box;
}

.contact-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(31, 41, 55, 0.06);
}

.contact-title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #1f2937;
  margin-bottom: 18rpx;
}

.contact-qr {
  width: 100%;
  border-radius: 14rpx;
  background: #f1f5f9;
}

.contact-note {
  display: block;
  margin-top: 16rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: #4b5563;
}
