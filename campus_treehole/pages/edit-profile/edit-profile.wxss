.page-container {
  min-height: 100vh;
  padding: 24rpx;
  background: #f7f9fc;
  box-sizing: border-box;
}

.form-card,
.tips-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 8rpx 24rpx rgba(31, 41, 55, 0.05);
}

.tips-card {
  margin-top: 24rpx;
}

.field-block {
  margin-bottom: 32rpx;
}

.field-block:last-child {
  margin-bottom: 0;
}

.media-grid {
  display: flex;
  gap: 20rpx;
}

.avatar-editor {
  width: 180rpx;
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.avatar-preview {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  border: 4rpx solid #ffffff;
  box-shadow: 0 8rpx 20rpx rgba(31, 41, 55, 0.12);
}

.avatar-tip {
  margin-top: 14rpx;
  font-size: 24rpx;
  color: #426089;
  font-weight: 600;
}

.cover-editor {
  flex: 1;
  height: 180rpx;
  border-radius: 20rpx;
  overflow: hidden;
  position: relative;
  background: #eef2f7;
}

.cover-preview {
  width: 100%;
  height: 100%;
  display: block;
}

.cover-empty {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #8a94a6;
  font-size: 24rpx;
}

.cover-mask {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 10rpx 14rpx;
  background: linear-gradient(to top, rgba(0, 0, 0, 0.45), rgba(0, 0, 0, 0));
}

.cover-tip {
  font-size: 22rpx;
  color: #ffffff;
}

.field-label {
  display: block;
  margin-bottom: 16rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #273142;
}

.field-textarea {
  width: 100%;
  height: 220rpx;
  padding: 24rpx;
  background: #f2f5fa;
  border-radius: 20rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  color: #273142;
}

.field-input {
  width: 100%;
  height: 92rpx;
  padding: 0 24rpx;
  background: #f2f5fa;
  border-radius: 20rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  color: #273142;
}

.tag-editor-wrap {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag-item {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  max-width: 100%;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #eef3ff;
}

.tag-item-text {
  max-width: 260rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 24rpx;
  color: #3c4f70;
}

.tag-item-del {
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  background: rgba(66, 96, 137, 0.2);
  color: #3f5e8c;
  font-size: 22rpx;
  line-height: 28rpx;
  text-align: center;
}

.tag-input-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.tag-input {
  flex: 1;
  min-width: 0;
}

.tag-add-btn {
  flex-shrink: 0;
  height: 92rpx;
  padding: 0 24rpx;
  border-radius: 20rpx;
  background: #426089;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tag-help {
  font-size: 22rpx;
  color: #8a94a6;
}

.field-count {
  display: block;
  margin-top: 12rpx;
  text-align: right;
  font-size: 22rpx;
  color: #8a94a6;
}

.tips-title {
  display: block;
  margin-bottom: 12rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #273142;
}

.tips-text {
  display: block;
  font-size: 24rpx;
  line-height: 1.7;
  color: #6b7280;
}

.action-bar {
  margin-top: 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

.save-btn {
  height: 92rpx;
  border-radius: 999rpx;
  background: #426089;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 600;
}

.save-btn-disabled {
  opacity: 0.5;
}
