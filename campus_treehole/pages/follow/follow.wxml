<!-- pages/follow/follow.wxml - 关注与粉丝列表 -->
<view class="page-container">
  <!-- Tab 栏 -->
  <view class="tab-bar">
    <view
      class="tab-item {{currentTab === index ? 'tab-item-active' : ''}}"
      wx:for="{{tabs}}" wx:key="index"
      bindtap="onTabChange" data-index="{{index}}"
    ><text>{{item}}</text></view>
  </view>

  <!-- 关注列表 -->
  <view class="user-list" wx:if="{{currentTab === 0}}">
    <view class="empty-state" wx:if="{{followingList.length === 0}}">
      <text class="empty-icon">👥</text>
      <text class="empty-text">还没有关注任何人</text>
    </view>
    <view class="user-card" wx:for="{{followingList}}" wx:key="_openid">
      <view class="user-card-left" bindtap="onUserTap" data-openid="{{item._openid}}" data-nickname="{{item.nickName}}">
        <image class="user-card-avatar" src="{{item.avatarUrl}}" mode="aspectFill"></image>
        <view class="user-card-info">
          <text class="user-card-name">{{item.nickName}}</text>
          <text class="user-card-college">{{item.college}}</text>
        </view>
      </view>
      <view class="user-card-actions">
        <view class="btn-follow followed" catchtap="onToggleFollow" data-openid="{{item._openid}}">
          <text>已关注</text>
        </view>
        <view class="btn-chat" catchtap="onChatTap" data-openid="{{item._openid}}" data-nickname="{{item.nickName}}">
          <text>💬</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 粉丝列表 -->
  <view class="user-list" wx:if="{{currentTab === 1}}">
    <view class="empty-state" wx:if="{{followerList.length === 0}}">
      <text class="empty-icon">🌟</text>
      <text class="empty-text">还没有粉丝</text>
    </view>
    <view class="user-card" wx:for="{{followerList}}" wx:key="_openid">
      <view class="user-card-left" bindtap="onUserTap" data-openid="{{item._openid}}" data-nickname="{{item.nickName}}">
        <image class="user-card-avatar" src="{{item.avatarUrl}}" mode="aspectFill"></image>
        <view class="user-card-info">
          <text class="user-card-name">{{item.nickName}}</text>
          <text class="user-card-college">{{item.college}}</text>
        </view>
      </view>
      <view class="user-card-actions">
        <view class="btn-chat" catchtap="onChatTap" data-openid="{{item._openid}}" data-nickname="{{item.nickName}}">
          <text>💬</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 发现 - 搜索用户 -->
  <view class="user-list" wx:if="{{currentTab === 2}}">
    <view class="search-bar">
      <image class="search-icon" src="/images/icon_search.png" mode="aspectFit"></image>
      <input class="search-input" placeholder="搜索用户..." bindinput="onSearchInput" value="{{searchKeyword}}" />
      <view class="search-clear" wx:if="{{searchKeyword}}" bindtap="onClearSearch">清除</view>
    </view>
    <view class="search-hint">
      <text>支持按昵称或学院搜索，向下拉也可以刷新推荐结果</text>
    </view>
    <view class="load-status" wx:if="{{searchLoading}}">
      <text class="load-text">搜索中...</text>
    </view>
    <view class="empty-state" wx:elif="{{searchList.length === 0}}">
      <text class="empty-icon">{{searchKeyword ? '🔎' : '✨'}}</text>
      <text class="empty-text">{{searchKeyword ? '没有找到相关用户' : '这里会推荐活跃用户'}}</text>
      <text class="empty-sub">{{searchKeyword ? '试试换个昵称或学院关键词' : '输入关键词可以更快找到同学'}}</text>
    </view>
    <view class="user-card" wx:for="{{searchList}}" wx:key="_openid">
      <view class="user-card-left" bindtap="onUserTap" data-openid="{{item._openid}}" data-nickname="{{item.nickName}}">
        <image class="user-card-avatar" src="{{item.avatarUrl}}" mode="aspectFill"></image>
        <view class="user-card-info">
          <text class="user-card-name">{{item.nickName}}</text>
          <text class="user-card-college">{{item.college}}</text>
        </view>
      </view>
      <view class="user-card-actions">
        <view class="btn-chat" catchtap="onChatTap" data-openid="{{item._openid}}" data-nickname="{{item.nickName}}">
          <text>💬</text>
        </view>
      </view>
    </view>
  </view>
</view>
