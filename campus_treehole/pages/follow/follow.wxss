/* pages/follow/follow.wxss - 关注与粉丝样式 */
.page-container { padding: 20rpx 28rpx; }

.quick-share {
  margin-bottom: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}
.quick-share-title {
  font-size: 24rpx;
  color: var(--on-surface-variant);
  font-weight: 600;
  padding-left: 8rpx;
}
.quick-share-sub {
  font-size: 22rpx;
  color: var(--outline-variant);
  padding-left: 8rpx;
  margin-top: 4rpx;
}
.author-card {
  border: 1px solid rgba(66, 96, 137, 0.22);
}

/* Tab 栏 */
.tab-bar {
  display: flex; background: var(--surface-container-low);
  border-radius: 999rpx; padding: 6rpx; margin-bottom: 24rpx;
}
.tab-item {
  flex: 1; text-align: center; padding: 16rpx 0;
  font-size: 26rpx; font-weight: 500; border-radius: 999rpx;
  color: var(--on-surface-variant);
}
.tab-item-active {
  background: var(--surface-container-lowest); color: var(--primary);
  font-weight: 700; box-shadow: 0 4px 12px rgba(44,51,56,0.06);
}

/* 搜索栏 */
.search-bar {
  display: flex; align-items: center; gap: 12rpx;
  padding: 16rpx 20rpx; background: var(--surface-container-lowest);
  border-radius: 999rpx; margin-bottom: 20rpx;
}
.search-icon { width: 32rpx; height: 32rpx; opacity: 0.4; }
.search-input { flex: 1; font-size: 28rpx; }
.search-clear {
  padding: 8rpx 18rpx; border-radius: 999rpx;
  background: var(--surface-container-low);
  font-size: 22rpx; color: var(--on-surface-variant);
}
.search-hint {
  margin: -6rpx 0 8rpx;
  font-size: 22rpx;
  color: var(--outline-variant);
}
.load-status {
  padding: 40rpx 0 12rpx;
  text-align: center;
}
.load-text {
  font-size: 24rpx;
  color: var(--outline-variant);
}

/* 用户列表 */
.user-list { display: flex; flex-direction: column; gap: 12rpx; }
.user-card {
  display: flex; align-items: center; justify-content: space-between;
  padding: 20rpx 24rpx; background: var(--surface-container-lowest);
  border-radius: var(--radius-m);
}
.user-card-left { display: flex; align-items: center; gap: 16rpx; flex: 1; }
.user-card-avatar { width: 84rpx; height: 84rpx; border-radius: 50%; }
.user-card-info { display: flex; flex-direction: column; gap: 4rpx; }
.user-card-name { font-size: 28rpx; font-weight: 600; color: var(--on-surface); }
.user-card-college { font-size: 22rpx; color: var(--outline-variant); }
.user-card-actions { display: flex; gap: 12rpx; align-items: center; }

/* 按钮 */
.btn-follow {
  padding: 10rpx 28rpx; border-radius: 999rpx; font-size: 24rpx; font-weight: 600;
  background: var(--primary); color: #fff;
}
.btn-follow.followed { background: var(--surface-container-low); color: var(--on-surface-variant); }
.btn-chat {
  width: 60rpx; height: 60rpx; border-radius: 50%;
  background: var(--surface-container-low); display: flex;
  align-items: center; justify-content: center; font-size: 28rpx;
}

/* 空状态 */
.empty-state { display: flex; flex-direction: column; align-items: center; padding: 80rpx 0; gap: 12rpx; }
.empty-icon { font-size: 60rpx; }
.empty-text { font-size: 28rpx; color: var(--outline-variant); }
.empty-sub { font-size: 24rpx; color: var(--outline-variant); opacity: 0.8; }
