<!-- 启动封面：数据就绪前展示，避免空白等待 -->
<view class="splash {{splashHidden ? 'splash-exit' : ''}}" wx:if="{{showSplash}}">
  <view class="splash-inner">
    <view class="splash-logo-ring">
      <image class="splash-logo-img" src="/images/logo_campus_box.png" mode="aspectFill"></image>
    </view>
    <text class="splash-name">校园便利盒</text>
    <view class="splash-bar"><view class="splash-bar-fill"></view></view>
    <text class="splash-hint">正在为你加载校园新鲜事…</text>
  </view>
</view>

<view class="page">
  <view class="subscribe-guide-mask" wx:if="{{showSubscribeGuideModal}}" bindtap="onCloseSubscribeGuideModal">
    <view class="subscribe-guide-modal" catchtap="">
      <text class="subscribe-guide-step">第{{subscribeGuideStep}}步 / 2</text>
      <text class="subscribe-guide-title">{{subscribeGuideStep === 1 ? '先开启核心互动提醒' : '继续开启收藏与下架提醒'}}</text>
      <text class="subscribe-guide-desc" wx:if="{{subscribeGuideStep === 1}}">你最常用的互动通知，建议优先开启：</text>
      <text class="subscribe-guide-desc" wx:else>再点一次补齐收藏/转发/下架提醒：</text>
      <view class="subscribe-guide-list">
        <block wx:if="{{subscribeGuideStep === 1}}">
          <text class="subscribe-guide-item">- 点赞提醒</text>
          <text class="subscribe-guide-item">- 私信提醒</text>
          <text class="subscribe-guide-item">- 评论互动提醒</text>
        </block>
        <block wx:else>
          <text class="subscribe-guide-item">- 谁收藏了你的帖子</text>
          <text class="subscribe-guide-item">- 谁转发了你的帖子</text>
          <text class="subscribe-guide-item">- 你收藏/想要的商品被下架</text>
          <text class="subscribe-guide-item">- 开启后可在设置页随时调整</text>
        </block>
      </view>
      <view class="subscribe-guide-actions">
        <view class="subscribe-guide-btn ghost" bindtap="onCloseSubscribeGuideModal">{{subscribeGuideStep === 1 ? '稍后再说' : '先不补充'}}</view>
        <view class="subscribe-guide-btn primary" bindtap="onEnableSubscribeFromGuide">
          {{subscribeGuideSubmitting ? '请求中...' : (subscribeGuideStep === 1 ? '开启第1步' : '开启第2步')}}
        </view>
      </view>
    </view>
  </view>

  <view class="announcement-modal-mask" wx:if="{{showAnnouncementModal}}" bindtap="onTapAnnouncementMask">
    <view class="announcement-modal" catchtap="">
      <view class="announcement-modal-close" bindtap="onCloseAnnouncementModal">×</view>
      <view class="announcement-modal-head">
        <text class="announcement-modal-badge">公告</text>
        <text class="announcement-modal-title">{{modalAnnouncement.title}}</text>
      </view>
      <image class="announcement-modal-cover" wx:if="{{modalAnnouncement.images && modalAnnouncement.images.length}}" src="{{modalAnnouncement.images[0]}}" mode="widthFix"></image>
      <text class="announcement-modal-content">{{modalAnnouncement.content}}</text>
      <view class="announcement-modal-actions">
        <view class="announcement-modal-btn ghost" bindtap="onCloseAnnouncementModal">关闭</view>
        <view class="announcement-modal-btn primary" bindtap="onOpenAnnouncementFromModal">查看详情</view>
      </view>
    </view>
  </view>

  <view class="index-ambient">
    <view class="ambient-orb ambient-orb-1"></view>
    <view class="ambient-orb ambient-orb-2"></view>
    <view class="ambient-orb ambient-orb-3"></view>
  </view>
  <view class="nav-bar" style="padding-top: {{statusBarHeight}}px;">
    <view class="nav-content">
      <view class="nav-tabs">
        <text class="nav-tab {{feedType === 'follow' ? 'nav-tab-active' : ''}}" bindtap="onFeedSwitch" data-type="follow">关注</text>
        <text class="nav-tab {{feedType === 'discover' ? 'nav-tab-active' : ''}}" bindtap="onFeedSwitch" data-type="discover">发现</text>
        <text class="nav-tab" bindtap="onOpenActivityZone" hover-class="nav-tab-tap" hover-stay-time="80">活动</text>
      </view>
      <view class="nav-search" bindtap="onSearchFocus">
        <view class="nav-search-ico" aria-hidden="true"></view>
        <input
          class="nav-search-input"
          placeholder="搜索帖子标题或正文"
          placeholder-class="nav-search-ph"
          value="{{searchKeyword}}"
          bindinput="onSearchInput"
          bindconfirm="onSearchConfirm"
          confirm-type="search"
        />
        <view class="nav-search-clear" wx:if="{{searchKeyword}}" catchtap="onClearSearch">清除</view>
      </view>
      <view class="nav-campus-row" bindtap="onOpenCampusPicker">
        <text class="nav-campus-tag">校区</text>
        <text class="nav-campus-name">{{selectedCampusName || '请选择校区'}}</text>
        <text class="nav-campus-arrow">›</text>
      </view>
    </view>
  </view>

  <view style="height: {{navOffsetHeight}}px;"></view>

  <view class="announcement-strip" wx:if="{{latestAnnouncement}}" bindtap="onOpenAnnouncement">
    <text class="announcement-badge">公告</text>
    <text class="announcement-title">{{latestAnnouncement.title}}</text>
    <text class="announcement-arrow">›</text>
  </view>

  <view class="campus-mask" wx:if="{{showCampusPicker}}" catchtouchmove="preventCampusMove">
    <view class="campus-sheet" catchtap="">
      <view class="campus-sheet-handle"></view>
      <text class="campus-sheet-title">选择你的校区</text>
      <text class="campus-sheet-sub">内容仅展示所选校区，可随时更换；支持简称、空格多关键词</text>
      <view class="campus-search-wrap">
        <view class="campus-search-ico" aria-hidden="true"></view>
        <input
          class="campus-search-input"
          placeholder="搜校名、简称或拼音片段，如 桂电 雁山"
          placeholder-class="campus-search-ph"
          value="{{campusQuery}}"
          bindinput="onCampusSearch"
          bindconfirm="onCampusSearchConfirm"
          confirm-type="search"
        />
        <view class="campus-search-clear" wx:if="{{campusQuery}}" catchtap="onClearCampusSearch">清除</view>
      </view>
      <scroll-view
        class="campus-list"
        scroll-y
        enhanced
        show-scrollbar="{{true}}"
        enable-flex
        scroll-with-animation
      >
        <view
          class="campus-item"
          wx:for="{{campusPickerList}}"
          wx:key="id"
          data-id="{{item.id}}"
          bindtap="onPickCampus"
        >
          <text class="campus-item-name">{{item.name}}</text>
          <text class="campus-item-arrow">›</text>
        </view>
        <view wx:if="{{!campusPickerList.length}}" class="campus-empty">未找到匹配校区，试试校名里的连续几个字或简称</view>
        <view class="campus-list-spacer"></view>
      </scroll-view>
    </view>
  </view>

  <scroll-view class="category-scroll" scroll-x enable-flex show-scrollbar="{{false}}">
    <view class="category-track">
      <view
        class="cat-tag {{currentCategory === index ? 'cat-active' : ''}}"
        wx:for="{{categories}}"
        wx:key="index"
        bindtap="onCategoryTap"
        data-index="{{index}}"
      >{{item}}</view>
    </view>
  </scroll-view>

  <!-- 骨架屏：首屏数据到达前占位 -->
  <view class="skeleton-feed" wx:if="{{showSkeleton}}">
    <view class="skeleton-col">
      <view class="skeleton-card"><view class="skeleton-img"></view><view class="skeleton-lines"><view class="skeleton-line w80"></view><view class="skeleton-line w60"></view></view></view>
      <view class="skeleton-card"><view class="skeleton-img skeleton-img-tall"></view><view class="skeleton-lines"><view class="skeleton-line w70"></view><view class="skeleton-line w50"></view></view></view>
    </view>
    <view class="skeleton-col">
      <view class="skeleton-card"><view class="skeleton-img skeleton-img-tall"></view><view class="skeleton-lines"><view class="skeleton-line w90"></view><view class="skeleton-line w40"></view></view></view>
      <view class="skeleton-card"><view class="skeleton-img"></view><view class="skeleton-lines"><view class="skeleton-line w60"></view><view class="skeleton-line w80"></view></view></view>
    </view>
  </view>

  <view class="page-hint" wx:if="{{!showSkeleton}}">
    <text>{{searchKeyword ? '正在按关键词筛选内容' : '下拉刷新获取最新动态'}}</text>
  </view>

  <view class="waterfall" wx:if="{{!showSkeleton}}">
    <view class="wf-col">
      <view class="wf-card wf-card-enter" wx:for="{{leftCol}}" wx:key="_id" bindtap="goToDetail" data-id="{{item._id}}" style="animation-delay: {{index * 40}}ms;">
        <view class="wf-activity-tag" wx:if="{{item.inActivityZone}}">活动</view>
        <view wx:if="{{item._coverSrc}}" class="wf-cover-wrap {{mediaLoadedMap[item._id] ? 'wf-cover-wrap-ready' : ''}}" style="{{coverHeightsMap[item._id] ? 'height:' + coverHeightsMap[item._id] + 'rpx;' : ''}}">
          <view class="wf-media-skeleton {{mediaLoadedMap[item._id] ? 'wf-media-skeleton-hidden' : ''}}"></view>
          <image class="wf-cover {{mediaLoadedMap[item._id] ? 'wf-cover-ready' : ''}}" src="{{item._coverSrc}}" mode="aspectFill" lazy-load bindload="onMediaLoad" binderror="onMediaLoad" data-key="{{item._id}}" />
        </view>
        <view wx:elif="{{item.videos && item.videos.length > 0}}" class="wf-video-wrap">
          <view class="wf-media-skeleton {{mediaLoadedMap[item._id] ? 'wf-media-skeleton-hidden' : ''}}"></view>
          <video class="wf-video-el" src="{{item.videos[0]}}" object-fit="cover" show-center-play-btn="{{false}}" show-play-btn="{{false}}" controls="{{false}}" muted="{{true}}" bindloadedmetadata="onMediaLoad" binderror="onMediaLoad" data-key="{{item._id}}"></video>
          <view class="video-badge"><text>视频</text></view>
        </view>
        <view wx:else class="wf-text-card">
          <text class="wf-text-only">{{item.content}}</text>
        </view>
        <view class="wf-info">
          <text class="wf-title">{{item.title || item.content}}</text>
          <view class="wf-footer">
            <view class="wf-author">
              <image class="wf-avatar" src="{{item.avatar || '/images/avatar_default.png'}}" lazy-load />
              <text class="wf-name">{{item.nickname || '匿名'}}</text>
            </view>
            <view class="wf-actions">
              <view class="wf-favor {{item.isFavored ? 'favored' : ''}}" catchtap="onFavorTap" data-id="{{item._id}}">
                <text class="favor-icon">{{item.isFavored ? '★' : '☆'}}</text>
              </view>
              <view class="wf-like {{item.isLiked ? 'liked' : ''}}" catchtap="onLikeTap" data-id="{{item._id}}">
                <text class="like-icon">{{item.isLiked ? '❤️' : '🤍'}}</text>
                <text class="like-num">{{item.likes || 0}}</text>
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view class="wf-col">
      <view class="wf-card wf-card-enter" wx:for="{{rightCol}}" wx:key="_id" bindtap="goToDetail" data-id="{{item._id}}" style="animation-delay: {{index * 40 + 20}}ms;">
        <view class="wf-activity-tag" wx:if="{{item.inActivityZone}}">活动</view>
        <view wx:if="{{item._coverSrc}}" class="wf-cover-wrap {{mediaLoadedMap[item._id] ? 'wf-cover-wrap-ready' : ''}}" style="{{coverHeightsMap[item._id] ? 'height:' + coverHeightsMap[item._id] + 'rpx;' : ''}}">
          <view class="wf-media-skeleton {{mediaLoadedMap[item._id] ? 'wf-media-skeleton-hidden' : ''}}"></view>
          <image class="wf-cover {{mediaLoadedMap[item._id] ? 'wf-cover-ready' : ''}}" src="{{item._coverSrc}}" mode="aspectFill" lazy-load bindload="onMediaLoad" binderror="onMediaLoad" data-key="{{item._id}}" />
        </view>
        <view wx:elif="{{item.videos && item.videos.length > 0}}" class="wf-video-wrap">
          <view class="wf-media-skeleton {{mediaLoadedMap[item._id] ? 'wf-media-skeleton-hidden' : ''}}"></view>
          <video class="wf-video-el" src="{{item.videos[0]}}" object-fit="cover" show-center-play-btn="{{false}}" show-play-btn="{{false}}" controls="{{false}}" muted="{{true}}" bindloadedmetadata="onMediaLoad" binderror="onMediaLoad" data-key="{{item._id}}"></video>
          <view class="video-badge"><text>视频</text></view>
        </view>
        <view wx:else class="wf-text-card">
          <text class="wf-text-only">{{item.content}}</text>
        </view>
        <view class="wf-info">
          <text class="wf-title">{{item.title || item.content}}</text>
          <view class="wf-footer">
            <view class="wf-author">
              <image class="wf-avatar" src="{{item.avatar || '/images/avatar_default.png'}}" lazy-load />
              <text class="wf-name">{{item.nickname || '匿名'}}</text>
            </view>
            <view class="wf-actions">
              <view class="wf-favor {{item.isFavored ? 'favored' : ''}}" catchtap="onFavorTap" data-id="{{item._id}}">
                <text class="favor-icon">{{item.isFavored ? '★' : '☆'}}</text>
              </view>
              <view class="wf-like {{item.isLiked ? 'liked' : ''}}" catchtap="onLikeTap" data-id="{{item._id}}">
                <text class="like-icon">{{item.isLiked ? '❤️' : '🤍'}}</text>
                <text class="like-num">{{item.likes || 0}}</text>
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="load-status" wx:if="{{loading || searchLoading}}">
    <text class="load-text">加载中...</text>
  </view>
  <view class="load-status empty" wx:elif="{{loadError}}">
    <text class="empty-emoji">⚠️</text>
    <text class="load-text">{{loadError}}</text>
  </view>
  <view class="load-status" wx:elif="{{!hasMore && posts.length > 0}}">
    <text class="load-text">已经到底了</text>
  </view>
  <view class="load-status empty" wx:elif="{{!loading && posts.length === 0}}">
    <text class="empty-emoji">{{searchKeyword ? '🔎' : '🫧'}}</text>
    <text class="load-text">{{searchKeyword ? '没有找到相关动态' : '还没有动态，快去发布吧'}}</text>
  </view>

  <view style="height: 180rpx;"></view>
</view>
