/* 首页：偏小红书 — 白底、大字、弱装饰 */
.page {
  position: relative;
  min-height: 100vh;
  background: #ffffff;
  width: 100%;
  overflow-x: hidden;
  box-sizing: border-box;
}

/* 顶部环境光：极弱，避免抢白底信息流 */
.index-ambient {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: 45vh;
  pointer-events: none;
  z-index: 0;
  overflow: hidden;
}

.ambient-orb {
  position: absolute;
  border-radius: 50%;
  filter: blur(80rpx);
  opacity: 0.12;
  animation: ambient-drift 14s ease-in-out infinite;
}

.ambient-orb-1 {
  width: 420rpx;
  height: 420rpx;
  background: #d4e4ff;
  top: -140rpx;
  right: -100rpx;
}

.ambient-orb-2 {
  width: 320rpx;
  height: 320rpx;
  background: #ffe4e8;
  top: 80rpx;
  left: -120rpx;
  animation-delay: -5s;
  opacity: 0.1;
}

.ambient-orb-3 {
  width: 280rpx;
  height: 280rpx;
  background: #e8f0ff;
  top: 200rpx;
  right: 10%;
  animation-delay: -9s;
  opacity: 0.1;
}

@keyframes ambient-drift {
  0%,
  100% {
    transform: translate(0, 0) scale(1);
  }
  33% {
    transform: translate(-24rpx, 16rpx) scale(1.06);
  }
  66% {
    transform: translate(16rpx, -12rpx) scale(0.96);
  }
}

.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: rgba(255, 255, 255, 0.96);
  backdrop-filter: saturate(180%) blur(20px);
  -webkit-backdrop-filter: saturate(180%) blur(20px);
  border-bottom: 1rpx solid #f0f0f0;
  box-shadow: none;
  transform: translateZ(0);
}

.nav-content {
  display: flex;
  flex-direction: column;
  align-items: stretch;
  padding: 12rpx 24rpx 16rpx;
  gap: 14rpx;
  box-sizing: border-box;
}

.nav-tabs {
  display: flex;
  align-items: flex-end;
  gap: 36rpx;
  flex-shrink: 0;
}

.nav-tab-tap {
  opacity: 0.72;
}

.nav-tab {
  position: relative;
  padding-bottom: 10rpx;
  font-size: 38rpx;
  color: #8a8a8a;
  font-weight: 600;
  letter-spacing: 0.5rpx;
  transition: color 0.2s ease, transform 0.2s ease;
}

.nav-tab-active {
  color: #111111;
  font-weight: 800;
  font-size: 44rpx;
}

.nav-tab-active::after {
  content: '';
  position: absolute;
  left: 50%;
  bottom: 0;
  width: 48rpx;
  height: 6rpx;
  border-radius: 999rpx;
  background: #ff2442;
  transform: translateX(-50%);
}

.nav-search {
  display: flex;
  align-items: center;
  width: 100%;
  min-width: 0;
  padding: 14rpx 22rpx 14rpx 20rpx;
  border-radius: 999rpx;
  box-sizing: border-box;
  border: 1rpx solid rgba(66, 96, 137, 0.14);
  background: linear-gradient(180deg, #fbfcfe 0%, #f3f6fa 100%);
  box-shadow:
    0 2rpx 10rpx rgba(44, 51, 56, 0.05),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.9);
}

.nav-search-ico {
  flex-shrink: 0;
  width: 34rpx;
  height: 34rpx;
  margin-right: 14rpx;
  border: 3rpx solid rgba(66, 96, 137, 0.35);
  border-radius: 50%;
  box-sizing: border-box;
  position: relative;
}

.nav-search-ico::after {
  content: '';
  position: absolute;
  width: 10rpx;
  height: 3rpx;
  border-radius: 2rpx;
  background: rgba(66, 96, 137, 0.45);
  right: -6rpx;
  bottom: -2rpx;
  transform: rotate(42deg);
  transform-origin: left center;
}

.nav-search-input {
  flex: 1;
  min-width: 0;
  font-size: 30rpx;
  color: #111111;
  height: 44rpx;
  line-height: 44rpx;
}

.nav-search-ph {
  color: #9aa3ad;
  font-size: 28rpx;
}

.nav-search-clear {
  flex-shrink: 0;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(66, 96, 137, 0.1);
  font-size: 24rpx;
  color: #426089;
  font-weight: 600;
}

.nav-campus-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 4rpx 4rpx 0;
}

.nav-campus-tag {
  font-size: 22rpx;
  color: #888888;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  background: #f0f4fa;
}

.nav-campus-name {
  flex: 1;
  min-width: 0;
  font-size: 28rpx;
  color: #426089;
  font-weight: 600;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.nav-campus-arrow {
  font-size: 36rpx;
  color: #bbbbbb;
  line-height: 1;
}

.announcement-strip {
  margin: 10rpx 24rpx 8rpx;
  padding: 16rpx 18rpx;
  border-radius: 16rpx;
  background: #f7f9fc;
  border: 1rpx solid #e8edf5;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.announcement-badge {
  flex-shrink: 0;
  font-size: 20rpx;
  color: #fff;
  background: #426089;
  border-radius: 999rpx;
  padding: 4rpx 12rpx;
}

.announcement-title {
  flex: 1;
  min-width: 0;
  font-size: 26rpx;
  color: #1f2b3d;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.announcement-arrow {
  flex-shrink: 0;
  font-size: 28rpx;
  color: #7f8ca2;
}

.announcement-modal-mask {
  position: fixed;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  z-index: 10080;
  background: rgba(0, 0, 0, 0.48);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 36rpx;
  box-sizing: border-box;
}

.subscribe-guide-mask {
  position: fixed;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  z-index: 10120;
  background: rgba(0, 0, 0, 0.52);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 34rpx;
  box-sizing: border-box;
}

.subscribe-guide-modal {
  width: 100%;
  background: #ffffff;
  border-radius: 26rpx;
  padding: 30rpx 24rpx 24rpx;
  box-sizing: border-box;
  box-shadow: 0 20rpx 56rpx rgba(0, 0, 0, 0.22);
}

.subscribe-guide-title {
  display: block;
  font-size: 36rpx;
  font-weight: 800;
  color: #111111;
}

.subscribe-guide-step {
  display: inline-block;
  margin-bottom: 8rpx;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: #426089;
  background: #eaf0fb;
}

.subscribe-guide-desc {
  display: block;
  margin-top: 10rpx;
  font-size: 26rpx;
  color: #495465;
}

.subscribe-guide-list {
  margin-top: 14rpx;
  padding: 16rpx 18rpx;
  border-radius: 14rpx;
  background: #f6f8fc;
}

.subscribe-guide-item {
  display: block;
  font-size: 25rpx;
  color: #42506a;
  line-height: 1.7;
}

.subscribe-guide-actions {
  margin-top: 20rpx;
  display: flex;
  gap: 12rpx;
}

.subscribe-guide-btn {
  flex: 1;
  height: 76rpx;
  border-radius: 14rpx;
  text-align: center;
  line-height: 76rpx;
  font-size: 28rpx;
  font-weight: 700;
}

.subscribe-guide-btn.ghost {
  color: #5d6b80;
  background: #eff2f7;
}

.subscribe-guide-btn.primary {
  color: #ffffff;
  background: linear-gradient(135deg, #426089, #5a7bab);
}

.announcement-modal {
  width: 100%;
  background: #ffffff;
  border-radius: 28rpx;
  padding: 28rpx 24rpx 24rpx;
  box-sizing: border-box;
  position: relative;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.2);
  max-height: 88vh;
  overflow-y: auto;
}

.announcement-modal-close {
  position: absolute;
  right: 18rpx;
  top: 12rpx;
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  text-align: center;
  line-height: 56rpx;
  font-size: 40rpx;
  color: #7e8794;
}

.announcement-modal-head {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 14rpx;
  padding-right: 44rpx;
}

.announcement-modal-badge {
  flex-shrink: 0;
  font-size: 22rpx;
  color: #fff;
  background: #426089;
  border-radius: 999rpx;
  padding: 4rpx 14rpx;
}

.announcement-modal-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1f2b3d;
}

.announcement-modal-content {
  display: block;
  font-size: 27rpx;
  color: #3f4651;
  line-height: 1.65;
  white-space: pre-wrap;
  max-height: none;
  overflow: visible;
}

.announcement-modal-cover {
  width: 100%;
  height: auto;
  max-height: 60vh;
  border-radius: 16rpx;
  margin-bottom: 14rpx;
  background: #f5f7fb;
}

.announcement-modal-actions {
  margin-top: 22rpx;
  display: flex;
  gap: 14rpx;
}

.announcement-modal-btn {
  flex: 1;
  height: 78rpx;
  border-radius: 14rpx;
  text-align: center;
  line-height: 78rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.announcement-modal-btn.ghost {
  background: #f3f5f8;
  color: #607086;
}

.announcement-modal-btn.primary {
  background: #426089;
  color: #fff;
}

.campus-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  /* 高于 custom-tab-bar（999），避免底部发布钮挡住校区列表 */
  z-index: 10050;
  background: rgba(0, 0, 0, 0.48);
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.campus-sheet {
  width: 100%;
  height: 86vh;
  max-height: 86vh;
  background: #ffffff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 12rpx 28rpx 0;
  padding-bottom: calc(12rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  box-shadow: 0 -16rpx 48rpx rgba(0, 0, 0, 0.12);
}

.campus-sheet-handle {
  align-self: center;
  width: 72rpx;
  height: 8rpx;
  border-radius: 999rpx;
  background: #e2e5ea;
  margin-bottom: 4rpx;
}

.campus-sheet-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #111111;
}

.campus-sheet-sub {
  font-size: 24rpx;
  color: #888888;
  line-height: 1.45;
}

.campus-search-wrap {
  display: flex;
  align-items: center;
  width: 100%;
  min-width: 0;
  padding: 12rpx 18rpx 12rpx 16rpx;
  border-radius: 999rpx;
  box-sizing: border-box;
  border: 1rpx solid rgba(66, 96, 137, 0.14);
  background: linear-gradient(180deg, #fbfcfe 0%, #f3f6fa 100%);
  box-shadow:
    0 2rpx 10rpx rgba(44, 51, 56, 0.05),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.9);
}

.campus-search-ico {
  flex-shrink: 0;
  width: 32rpx;
  height: 32rpx;
  margin-right: 12rpx;
  border: 3rpx solid rgba(66, 96, 137, 0.32);
  border-radius: 50%;
  box-sizing: border-box;
  position: relative;
}

.campus-search-ico::after {
  content: '';
  position: absolute;
  width: 9rpx;
  height: 3rpx;
  border-radius: 2rpx;
  background: rgba(66, 96, 137, 0.42);
  right: -5rpx;
  bottom: -1rpx;
  transform: rotate(42deg);
  transform-origin: left center;
}

.campus-search-input {
  flex: 1;
  min-width: 0;
  padding: 0;
  margin: 0;
  height: 44rpx;
  line-height: 44rpx;
  font-size: 28rpx;
  color: #111111;
  background: transparent;
}

.campus-search-ph {
  color: #9aa3ad;
  font-size: 26rpx;
}

.campus-search-clear {
  flex-shrink: 0;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(66, 96, 137, 0.1);
  font-size: 24rpx;
  color: #426089;
  font-weight: 600;
}

/* flex 子项 height:0 + flex:1，scroll-view 才能占满剩余高度并正常滚动 */
.campus-list {
  flex: 1;
  height: 0;
  min-height: 200rpx;
  width: 100%;
  box-sizing: border-box;
}

.campus-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 28rpx 8rpx 28rpx 4rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.campus-item:active {
  background: #f7f9fc;
}

.campus-item-name {
  flex: 1;
  min-width: 0;
  font-size: 30rpx;
  color: #222222;
  line-height: 1.4;
}

.campus-item-arrow {
  flex-shrink: 0;
  font-size: 32rpx;
  color: #d0d4db;
  line-height: 1;
}

.campus-empty {
  padding: 48rpx 16rpx 24rpx;
  font-size: 26rpx;
  color: #999999;
  text-align: center;
  line-height: 1.5;
}

/* 列表底部留白，最后一条可滚到视觉舒适区 */
.campus-list-spacer {
  height: 48rpx;
  width: 100%;
}

.category-scroll {
  position: relative;
  z-index: 1;
  white-space: nowrap;
  padding: 20rpx 0 16rpx 20rpx;
  background: #ffffff;
  box-sizing: border-box;
}

.category-track {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding-right: 20rpx;
}

.page-hint {
  padding: 14rpx 24rpx 8rpx;
  font-size: 26rpx;
  color: #9a9a9a;
}

.cat-tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 0;
  padding: 14rpx 22rpx 16rpx;
  border-radius: 0;
  background: transparent;
  border: none;
  border-bottom: 4rpx solid transparent;
  color: #666666;
  font-size: 30rpx;
  font-weight: 600;
  box-sizing: border-box;
  transition: color 0.2s ease, border-color 0.2s ease, font-weight 0.2s ease;
}

.cat-active {
  background: transparent;
  color: #111111;
  font-weight: 800;
  font-size: 32rpx;
  border-bottom-color: #ff2442;
  transform: none;
  box-shadow: none;
}

.waterfall {
  position: relative;
  z-index: 1;
  display: flex;
  gap: 16rpx;
  width: 100%;
  padding: 16rpx;
  box-sizing: border-box;
  align-items: flex-start;
}

.wf-col {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  will-change: transform;
}

/* 双列卡片：白底、轻描边、圆角封面 */
.wf-activity-tag {
  position: absolute;
  top: 12rpx;
  left: 12rpx;
  z-index: 3;
  font-size: 20rpx;
  font-weight: 700;
  color: #fff;
  background: linear-gradient(135deg, #ff2442 0%, #ff6b4a 100%);
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  box-shadow: 0 4rpx 12rpx rgba(255, 36, 66, 0.35);
}

.wf-card {
  position: relative;
  overflow: hidden;
  border-radius: 16rpx;
  background: #ffffff;
  width: 100%;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  border: 1rpx solid #f0f0f0;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
  transform: translateZ(0);
  backface-visibility: hidden;
}

/* 图片区：按原图比例算展示高度并夹在 min~max，aspectFill 填满（过长上下裁、过扁左右裁） */
.wf-cover-wrap {
  position: relative;
  width: 100%;
  overflow: hidden;
  flex-shrink: 0;
  line-height: 0;
  background: var(--surface-container-low);
}

/* 解码前固定高度，保证绝对定位封面有参照；解码后用内联 height 覆盖 */
.wf-cover-wrap:not(.wf-cover-wrap-ready) {
  height: 320rpx;
}

.wf-cover-wrap.wf-cover-wrap-ready {
  min-height: 0;
}

.wf-card:active {
  transform: scale(0.985) translateZ(0);
  opacity: 0.98;
  transition: transform 0.12s ease, opacity 0.12s ease;
}

.wf-cover {
  position: absolute;
  left: 0;
  top: 0;
  display: block;
  width: 100%;
  height: 100%;
  vertical-align: top;
  opacity: 0;
  transition: opacity 220ms ease;
  animation: wfCoverSafeShow 0s 2s forwards;
}

.wf-cover-ready {
  opacity: 1;
  animation: none;
}

@keyframes wfCoverSafeShow {
  to { opacity: 1; }
}

/* 视频：固定竖版比例（约 4:5），避免无高度时塌陷，观感接近小红书封面 */
.wf-video-wrap {
  position: relative;
  width: 100%;
  overflow: hidden;
  flex-shrink: 0;
  height: 0;
  padding-bottom: 125%;
  box-sizing: border-box;
  background: var(--on-surface);
}

.wf-video-el {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
}

.wf-media-skeleton {
  position: absolute;
  inset: 0;
  background: linear-gradient(90deg, var(--surface-container) 25%, var(--surface-container-low) 50%, var(--surface-container) 75%);
  background-size: 220% 100%;
  animation: wfShimmer 1.2s linear infinite, wfSkeletonSafeHide 0s 2.5s forwards;
  z-index: 1;
}

.wf-media-skeleton-hidden {
  opacity: 0;
  pointer-events: none;
  transition: opacity 180ms ease;
  animation: none;
}

@keyframes wfSkeletonSafeHide {
  to { opacity: 0; pointer-events: none; }
}

.video-badge {
  position: absolute;
  right: 12rpx;
  bottom: 12rpx;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(0, 0, 0, 0.55);
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 600;
  z-index: 2;
}

.wf-text-card {
  display: flex;
  align-items: center;
  width: 100%;
  min-height: 360rpx;
  padding: 24rpx 22rpx;
  background: linear-gradient(145deg, var(--secondary-container), var(--primary-container));
  box-sizing: border-box;
  flex-shrink: 0;
}

.wf-text-only {
  overflow: hidden;
  font-size: 30rpx;
  line-height: 1.55;
  color: var(--on-secondary-container);
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 6;
}

.wf-info {
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  padding: 16rpx 18rpx 18rpx;
  box-sizing: border-box;
}

.wf-title {
  display: -webkit-box;
  overflow: hidden;
  margin-bottom: 10rpx;
  font-size: 30rpx;
  line-height: 1.4;
  color: #111111;
  font-weight: 700;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  word-break: break-word;
}

.wf-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8rpx;
  margin-top: 0;
}

.wf-author {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.wf-avatar {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.wf-name {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 24rpx;
  color: #888888;
}

.wf-actions {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-shrink: 0;
}

.wf-favor {
  display: flex;
  align-items: center;
  padding: 4rpx;
}

.wf-favor .favor-icon {
  font-size: 32rpx;
  color: #bbbbbb;
  line-height: 1;
}

.wf-favor.favored .favor-icon {
  color: #c9a227;
}

.wf-like {
  display: flex;
  align-items: center;
  gap: 6rpx;
  flex-shrink: 0;
}

.like-icon {
  font-size: 28rpx;
}

.like-num {
  font-size: 24rpx;
  color: #888888;
}

.wf-like.liked .like-num {
  color: #ff2442;
}

.load-status {
  padding: 40rpx 0;
  text-align: center;
}

.load-status.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-emoji {
  margin-bottom: 16rpx;
  font-size: 72rpx;
}

.load-text {
  font-size: 28rpx;
  color: #9a9a9a;
}

/* ===== 启动封面 ===== */
.splash {
  position: fixed;
  inset: 0;
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(155deg, var(--surface) 0%, var(--surface-container-low) 42%, var(--primary-container) 120%);
  opacity: 1;
  transition: opacity 0.5s ease;
  overflow: hidden;
}
.splash::before {
  content: '';
  position: absolute;
  width: 600rpx;
  height: 600rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(66, 96, 137, 0.12) 0%, transparent 70%);
  top: -200rpx;
  right: -160rpx;
  animation: splash-bg-pulse 4s ease-in-out infinite;
}
@keyframes splash-bg-pulse {
  0%,
  100% {
    transform: scale(1);
    opacity: 1;
  }
  50% {
    transform: scale(1.08);
    opacity: 0.85;
  }
}
.splash-exit { opacity: 0; pointer-events: none; }
.splash-inner {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 28rpx;
}
.splash-logo-ring {
  width: 176rpx;
  height: 176rpx;
  border-radius: 50%;
  overflow: hidden;
  box-shadow:
    0 20rpx 56rpx rgba(66, 96, 137, 0.22),
    0 0 0 8rpx rgba(255, 255, 255, 0.75);
  animation: splash-logo-pop 0.85s cubic-bezier(0.22, 1, 0.36, 1) both;
}
.splash-logo-img {
  width: 100%;
  height: 100%;
  display: block;
}
@keyframes splash-logo-pop {
  from {
    opacity: 0;
    transform: scale(0.82);
  }
  to {
    opacity: 1;
    transform: scale(1);
  }
}
.splash-name {
  font-size: 42rpx;
  font-weight: 800;
  color: var(--primary);
  letter-spacing: 1rpx;
  animation: splash-fade-up 0.7s ease 0.12s both;
}
@keyframes splash-fade-up {
  from {
    opacity: 0;
    transform: translateY(16rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}
.splash-bar {
  width: 280rpx;
  height: 10rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.55);
  overflow: hidden;
  box-shadow: inset 0 1rpx 3rpx rgba(44, 51, 56, 0.08);
  animation: splash-fade-up 0.7s ease 0.2s both;
}
.splash-bar-fill {
  width: 100%;
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, var(--primary), var(--accent), var(--primary-container));
  background-size: 200% 100%;
  animation: splashProgress 2.2s ease-in-out infinite, splash-shimmer 2.8s linear infinite;
  transform-origin: left center;
}
.splash-hint {
  font-size: 24rpx;
  color: var(--on-surface-variant);
  animation: splash-fade-up 0.7s ease 0.28s both;
}

@keyframes splashProgress {
  0%   { transform: scaleX(0); }
  50%  { transform: scaleX(0.72); }
  100% { transform: scaleX(1); }
}

@keyframes splash-shimmer {
  0% {
    background-position: 0% 50%;
  }
  100% {
    background-position: 200% 50%;
  }
}

/* ===== 骨架屏 ===== */
.skeleton-feed {
  display: flex;
  gap: 16rpx;
  padding: 16rpx;
  box-sizing: border-box;
}
.skeleton-col {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.skeleton-card {
  border-radius: 16rpx;
  background: #ffffff;
  overflow: hidden;
  border: 1rpx solid #f0f0f0;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}
.skeleton-img {
  width: 100%;
  height: 320rpx;
  background: linear-gradient(90deg, var(--surface-container) 25%, var(--surface-container-low) 50%, var(--surface-container) 75%);
  background-size: 220% 100%;
  animation: wfShimmer 1.2s linear infinite;
}
.skeleton-img-tall { height: 400rpx; }
.skeleton-lines {
  padding: 22rpx 18rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.skeleton-line {
  height: 24rpx;
  border-radius: 10rpx;
  background: linear-gradient(90deg, var(--surface-container) 25%, var(--surface-container-low) 50%, var(--surface-container) 75%);
  background-size: 220% 100%;
  animation: wfShimmer 1.2s linear infinite;
}
.skeleton-line.w90 { width: 90%; }
.skeleton-line.w80 { width: 80%; }
.skeleton-line.w70 { width: 70%; }
.skeleton-line.w60 { width: 60%; }
.skeleton-line.w50 { width: 50%; }
.skeleton-line.w40 { width: 40%; }

/* ===== 卡片入场动画 ===== */
.wf-card-enter {
  animation: wfCardIn 0.48s cubic-bezier(0.22, 1, 0.36, 1) both;
}
@keyframes wfCardIn {
  from {
    opacity: 0;
    transform: translateY(36rpx) scale(0.97);
  }
  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

@keyframes wfShimmer {
  0% {
    background-position: 200% 0;
  }
  100% {
    background-position: -20% 0;
  }
}

@media (max-width: 360px) {
  .nav-tabs {
    gap: 40rpx;
  }

  .nav-tab {
    font-size: 34rpx;
  }

  .nav-tab-active {
    font-size: 40rpx;
  }

  .category-track {
    gap: 4rpx;
  }

  .cat-tag {
    padding: 12rpx 16rpx 14rpx;
    font-size: 28rpx;
  }

  .cat-active {
    font-size: 30rpx;
  }

  .waterfall {
    gap: 16rpx;
    padding: 16rpx;
  }

  .wf-title {
    font-size: 28rpx;
  }
}
