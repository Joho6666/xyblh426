/* =============================================
   login.wxss — 四季场景登录页
   春(spring) 夏(summer) 秋(autumn) 冬(winter)
   ============================================= */

/* ── 基础 ── */
.login-page {
  position: relative;
  width: 100vw;
  min-height: 100vh;
  overflow: hidden;
  transition: background 1.5s ease;
}

/* ── 季节背景色 ── */
.season-spring { background: linear-gradient(170deg, #fce4ec 0%, #e8f5e9 40%, #f1f8e9 100%); }
.season-summer { background: linear-gradient(170deg, #b3e5fc 0%, #e0f7fa 35%, #e8f5e9 100%); }
.season-autumn { background: linear-gradient(170deg, #fff3e0 0%, #ffe0b2 40%, #fff8e1 100%); }
.season-winter { background: linear-gradient(170deg, #e3f2fd 0%, #e8eaf6 40%, #f3e5f5 100%); }

/* ── 光晕层 ── */
.bg-layer {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  z-index: 0;
  transition: background 1.5s ease;
}
.season-spring .bg-layer {
  background: radial-gradient(ellipse at 30% 20%, rgba(248,187,208,0.4) 0%, transparent 55%),
              radial-gradient(ellipse at 75% 85%, rgba(165,214,167,0.3) 0%, transparent 50%);
}
.season-summer .bg-layer {
  background: radial-gradient(ellipse at 70% 8%, rgba(255,241,118,0.5) 0%, transparent 45%),
              radial-gradient(ellipse at 25% 65%, rgba(129,212,250,0.3) 0%, transparent 50%);
}
.season-autumn .bg-layer {
  background: radial-gradient(ellipse at 35% 25%, rgba(255,183,77,0.35) 0%, transparent 50%),
              radial-gradient(ellipse at 75% 80%, rgba(239,108,0,0.2) 0%, transparent 45%);
}
.season-winter .bg-layer {
  background: radial-gradient(ellipse at 50% 15%, rgba(187,222,251,0.5) 0%, transparent 50%),
              radial-gradient(ellipse at 30% 75%, rgba(206,147,216,0.2) 0%, transparent 45%);
}

/* ── 场景容器 ── */
.scene {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  z-index: 1;
  pointer-events: none;
  animation: sceneIn 0.8s ease both;
}
@keyframes sceneIn { from { opacity: 0; } to { opacity: 1; } }

/* ── 季节过渡 ── */
.season-fade .scene,
.season-fade .login-content { opacity: 0.15; }
.scene, .login-content { transition: opacity 0.4s ease; }


/* ==============================================
   🌸 春天 — 桃花树 · 花园 · 蝴蝶 · 小猫
   ============================================== */

/* ── 桃花树（右上，左移避开胶囊按钮区） ── */
.sp-tree {
  position: absolute;
  top: 28rpx;
  right: 100rpx;
  width: 260rpx;
  height: 340rpx;
}
.sp-trunk {
  position: absolute;
  bottom: 0;
  left: 48%;
  width: 20rpx;
  height: 175rpx;
  background: linear-gradient(90deg, #4e342e, #6d4c41 45%, #5d4037);
  border-radius: 8rpx;
  box-shadow: inset -2rpx 0 4rpx rgba(0,0,0,0.12);
}
.sp-crown {
  position: absolute;
  border-radius: 50%;
  box-shadow: 0 6rpx 28rpx rgba(233,30,99,0.18);
}
/* 树冠上的花苞亮点 */
.sp-blossom {
  position: absolute;
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: radial-gradient(circle, #fff 0%, #fce4ec 40%, #f48fb1 100%);
  box-shadow: 0 0 10rpx rgba(244,143,177,0.55);
  animation: blossomTwinkle 2.8s ease-in-out infinite;
}
.sp-bl1 { top: 48rpx; left: 32rpx; animation-delay: 0s; }
.sp-bl2 { top: 28rpx; left: 95rpx; animation-delay: 0.5s; }
.sp-bl3 { top: 72rpx; left: 118rpx; animation-delay: 1s; }
.sp-bl4 { top: 22rpx; right: 48rpx; animation-delay: 0.3s; }
.sp-bl5 { top: 58rpx; right: 22rpx; animation-delay: 0.8s; }
@keyframes blossomTwinkle {
  0%, 100% { transform: scale(1); opacity: 0.75; }
  50%      { transform: scale(1.15); opacity: 1; }
}
.sp-cr1 {
  width: 190rpx; height: 155rpx;
  background: radial-gradient(circle at 40% 40%, #f8bbd0 0%, #f48fb1 55%, rgba(236,64,122,0.2) 100%);
  top: 0; left: -10rpx;
}
.sp-cr2 {
  width: 145rpx; height: 125rpx;
  background: radial-gradient(circle at 50% 38%, #fce4ec 0%, #f8bbd0 50%, rgba(248,187,208,0.25) 100%);
  top: -30rpx; left: 55rpx;
}
.sp-cr3 {
  width: 125rpx; height: 115rpx;
  background: radial-gradient(circle at 58% 48%, #f48fb1 0%, #ec407a 55%, rgba(236,64,122,0.15) 100%);
  top: 12rpx; right: -10rpx;
}

/* ── 花瓣 ── */
.sp-petal {
  position: absolute;
  background: radial-gradient(ellipse, #ffcdd2 30%, #f8bbd0 70%, rgba(248,187,208,0.15) 100%);
  border-radius: 50% 50% 50% 10%;
  opacity: 0;
  box-shadow: 0 0 6rpx rgba(233,30,99,0.2);
}
.sp-p1  { left: 6%;  top: -3%; width: 18rpx; height: 24rpx; animation: petalDrift 6s ease-in infinite 0s; }
.sp-p2  { left: 18%; top: -6%; width: 22rpx; height: 28rpx; animation: petalDrift 7s ease-in infinite 0.8s; }
.sp-p3  { left: 30%; top: -2%; width: 16rpx; height: 20rpx; animation: petalDrift 5.5s ease-in infinite 1.6s; }
.sp-p4  { left: 42%; top: -5%; width: 20rpx; height: 26rpx; animation: petalDrift 6.5s ease-in infinite 2.4s; }
.sp-p5  { left: 54%; top: -4%; width: 14rpx; height: 18rpx; animation: petalDrift 7.5s ease-in infinite 0.4s; }
.sp-p6  { left: 66%; top: -7%; width: 24rpx; height: 30rpx; animation: petalDrift 6s ease-in infinite 1.2s; }
.sp-p7  { left: 78%; top: -1%; width: 18rpx; height: 22rpx; animation: petalDrift 5s ease-in infinite 2.0s; }
.sp-p8  { left: 88%; top: -5%; width: 20rpx; height: 24rpx; animation: petalDrift 7s ease-in infinite 3.0s; }
.sp-p9  { left: 12%; top: -3%; width: 16rpx; height: 22rpx; animation: petalDrift 6s ease-in infinite 3.8s; }
.sp-p10 { left: 50%; top: -6%; width: 22rpx; height: 26rpx; animation: petalDrift 5.5s ease-in infinite 4.5s; }
.sp-p11 { left: 72%; top: -2%; width: 14rpx; height: 18rpx; animation: petalDrift 7s ease-in infinite 5.0s; }
.sp-p12 { left: 38%; top: -4%; width: 18rpx; height: 24rpx; animation: petalDrift 6.5s ease-in infinite 5.5s; }

@keyframes petalDrift {
  0%   { transform: translateY(0) rotate(0deg) translateX(0); opacity: 0; }
  6%   { opacity: 0.85; }
  25%  { transform: translateY(28vh) rotate(80deg) translateX(35rpx); }
  50%  { transform: translateY(55vh) rotate(170deg) translateX(-25rpx); opacity: 0.7; }
  75%  { transform: translateY(80vh) rotate(260deg) translateX(40rpx); opacity: 0.4; }
  100% { transform: translateY(108vh) rotate(360deg) translateX(-15rpx); opacity: 0; }
}

/* ── 花园 ── */
.sp-garden {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  height: 180rpx;
  background: linear-gradient(to top, #43a047 0%, #66bb6a 25%, #81c784 50%, #a5d6a7 75%, transparent 100%);
  border-radius: 55% 45% 0 0 / 50rpx 40rpx 0 0;
}
.sp-grass {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  height: 36rpx;
  background: #388e3c;
}

/* ── 花朵 ── */
.sp-fl {
  position: absolute;
  border-radius: 50%;
  animation: flowerSway 3s ease-in-out infinite;
  z-index: 2;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.08);
}
.sp-fl::before {
  content: '';
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  width: 38%;
  height: 38%;
  background: rgba(255,255,255,0.9);
  border-radius: 50%;
  z-index: 1;
}
.sp-fl::after {
  content: '';
  position: absolute;
  top: 90%; left: 50%; transform: translateX(-50%);
  width: 3rpx; height: 38rpx;
  background: linear-gradient(to bottom, #81c784, #43a047);
  border-radius: 2rpx;
}
.sp-f1 { width: 18rpx; height: 18rpx; background: #e91e63; bottom: 150rpx; left: 8%;  animation-delay: 0s; }
.sp-f2 { width: 22rpx; height: 22rpx; background: #fdd835; bottom: 158rpx; left: 20%; animation-delay: 0.4s; }
.sp-f3 { width: 16rpx; height: 16rpx; background: #ce93d8; bottom: 144rpx; left: 33%; animation-delay: 0.8s; }
.sp-f4 { width: 20rpx; height: 20rpx; background: #ff7043; bottom: 154rpx; left: 45%; animation-delay: 0.2s; }
.sp-f5 { width: 14rpx; height: 14rpx; background: #fff176; bottom: 148rpx; left: 58%; animation-delay: 0.6s; }
.sp-f6 { width: 24rpx; height: 24rpx; background: #f48fb1; bottom: 162rpx; left: 70%; animation-delay: 1.0s; }
.sp-f7 { width: 18rpx; height: 18rpx; background: #ba68c8; bottom: 152rpx; left: 82%; animation-delay: 0.3s; }
.sp-f8 { width: 16rpx; height: 16rpx; background: #ef5350; bottom: 142rpx; left: 93%; animation-delay: 0.7s; }

@keyframes flowerSway {
  0%, 100% { transform: rotate(0deg); }
  30%  { transform: rotate(4deg); }
  70%  { transform: rotate(-4deg); }
}

/* ── 蝴蝶 ── */
.sp-bf {
  position: absolute;
  width: 8rpx; height: 16rpx;
  border-radius: 40%;
  z-index: 3;
}
.sp-bf::before,
.sp-bf::after {
  content: '';
  position: absolute;
  top: -2rpx;
  width: 16rpx; height: 14rpx;
  border-radius: 50%;
  animation: wingFlap 0.25s ease-in-out infinite alternate;
}
.sp-bf::before { right: 100%; transform-origin: right center; }
.sp-bf::after  { left: 100%;  transform-origin: left center; animation-direction: alternate-reverse; }

.sp-bf1 { background: #4e342e; bottom: 260rpx; left: 100rpx; animation: bfPath1 8s ease-in-out infinite; }
.sp-bf1::before, .sp-bf1::after {
  background: linear-gradient(145deg, #fff9c4 0%, #ffb74d 45%, #ff7043 100%);
  box-shadow: 0 0 8rpx rgba(255,152,0,0.35);
}

.sp-bf2 { background: #37474f; bottom: 220rpx; right: 130rpx; animation: bfPath2 9s ease-in-out infinite 2s; }
.sp-bf2::before, .sp-bf2::after {
  background: linear-gradient(145deg, #e1f5fe 0%, #4fc3f7 50%, #0288d1 100%);
  box-shadow: 0 0 8rpx rgba(3,169,244,0.35);
}

.sp-bf3 { background: #4a148c; bottom: 290rpx; left: 46%; animation: bfPath3 7s ease-in-out infinite 4s; }
.sp-bf3::before, .sp-bf3::after {
  background: linear-gradient(145deg, #f3e5f5 0%, #ce93d8 50%, #8e24aa 100%);
  box-shadow: 0 0 8rpx rgba(171,71,188,0.35);
}

/* 春日柔光 */
.sp-sun-glow {
  position: absolute;
  top: 20rpx; left: 15%;
  width: 140rpx; height: 140rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(255,253,231,0.55) 0%, rgba(255,241,118,0.15) 45%, transparent 70%);
  animation: springSunPulse 5s ease-in-out infinite;
}
@keyframes springSunPulse {
  0%, 100% { transform: scale(1); opacity: 0.85; }
  50%      { transform: scale(1.12); opacity: 1; }
}

@keyframes wingFlap {
  from { transform: scaleX(1); }
  to   { transform: scaleX(0.25); }
}
@keyframes bfPath1 {
  0%   { transform: translate(0, 0); }
  25%  { transform: translate(60rpx, -40rpx); }
  50%  { transform: translate(120rpx, 20rpx); }
  75%  { transform: translate(60rpx, -30rpx); }
  100% { transform: translate(0, 0); }
}
@keyframes bfPath2 {
  0%   { transform: translate(0, 0); }
  25%  { transform: translate(-50rpx, -35rpx); }
  50%  { transform: translate(-100rpx, 15rpx); }
  75%  { transform: translate(-50rpx, -25rpx); }
  100% { transform: translate(0, 0); }
}
@keyframes bfPath3 {
  0%   { transform: translate(0, 0); }
  33%  { transform: translate(40rpx, -50rpx); }
  66%  { transform: translate(-30rpx, -20rpx); }
  100% { transform: translate(0, 0); }
}

/* ── 小猫（五官 + 渐变毛色） ── */
.sp-cat {
  position: absolute;
  bottom: 138rpx;
  left: 36rpx;
  z-index: 3;
  animation: catPlay 4s ease-in-out infinite;
  filter: drop-shadow(0 4rpx 6rpx rgba(0,0,0,0.12));
}
.sp-cat-body {
  width: 48rpx;
  height: 30rpx;
  background: linear-gradient(165deg, #ffb74d 0%, #ff9800 45%, #f57c00 100%);
  border-radius: 50%;
  box-shadow: inset 0 -4rpx 0 rgba(230,81,0,0.15);
}
.sp-cat-head {
  position: absolute;
  top: -18rpx;
  left: -2rpx;
  width: 28rpx;
  height: 24rpx;
  background: linear-gradient(160deg, #ffcc80 0%, #ff9800 55%, #fb8c00 100%);
  border-radius: 48% 48% 45% 45%;
}
.sp-cat-ear {
  position: absolute;
  top: -10rpx;
  width: 0;
  height: 0;
  border-left: 7rpx solid transparent;
  border-right: 7rpx solid transparent;
  border-bottom: 12rpx solid #fb8c00;
}
.sp-ear-l { left: 0; transform: rotate(-12deg); }
.sp-ear-r { right: 0; transform: rotate(12deg); }
.sp-cat-ear::after {
  content: '';
  position: absolute;
  top: 4rpx;
  width: 7rpx;
  height: 7rpx;
  background: #ffccbc;
  border-radius: 50%;
}
.sp-ear-l::after { left: -2rpx; }
.sp-ear-r::after { right: -2rpx; left: auto; }
.sp-cat-eye {
  position: absolute;
  top: 10rpx;
  width: 6rpx;
  height: 7rpx;
  background: #263238;
  border-radius: 50%;
  animation: catBlink 4.5s ease-in-out infinite;
}
.sp-ce-l { left: 5rpx; }
.sp-ce-r { right: 5rpx; }
.sp-cat-eye::after {
  content: '';
  position: absolute;
  top: 1rpx;
  left: 1rpx;
  width: 2rpx;
  height: 2rpx;
  background: #fff;
  border-radius: 50%;
}
@keyframes catBlink {
  0%, 92%, 100% { transform: scaleY(1); }
  94%, 98% { transform: scaleY(0.08); }
}
.sp-cat-nose {
  position: absolute;
  top: 14rpx;
  left: 50%;
  margin-left: -4rpx;
  width: 8rpx;
  height: 6rpx;
  background: #ff8a80;
  border-radius: 40% 40% 50% 50%;
}
.sp-cat-whisker {
  position: absolute;
  top: 15rpx;
  height: 2rpx;
  background: rgba(66,66,66,0.35);
  border-radius: 2rpx;
}
.sp-wh1 { left: -18rpx; width: 16rpx; transform: rotate(-8deg); }
.sp-wh2 { left: -18rpx; width: 14rpx; top: 18rpx; transform: rotate(5deg); }
.sp-wh3 { right: -18rpx; width: 16rpx; transform: rotate(8deg); }
.sp-wh4 { right: -18rpx; width: 14rpx; top: 18rpx; transform: rotate(-5deg); }

.sp-cat-tail {
  position: absolute;
  right: -16rpx;
  top: -6rpx;
  width: 28rpx;
  height: 18rpx;
  border-top: 5rpx solid #ff9800;
  border-right: 5rpx solid #f57c00;
  border-radius: 0 20rpx 0 0;
  animation: tailSwish 1.5s ease-in-out infinite;
  transform-origin: left bottom;
}

@keyframes catPlay {
  0%, 100% { transform: translate(0, 0); }
  20% { transform: translate(15rpx, -12rpx); }
  40% { transform: translate(25rpx, 0); }
  60% { transform: translate(10rpx, -8rpx); }
  80% { transform: translate(20rpx, 0); }
}
@keyframes tailSwish {
  0%, 100% { transform: rotate(-15deg); }
  50%      { transform: rotate(25deg); }
}


/* ==============================================
   ☀️ 夏天 — 大海 · 沙滩 · 阳光
   ============================================== */

/* ── 太阳 ── */
.sm-sun {
  position: absolute;
  top: 25rpx; right: 35rpx;
  width: 120rpx; height: 120rpx;
  border-radius: 50%;
  background: radial-gradient(circle, #fff9c4 0%, #fdd835 40%, #ffb300 70%, rgba(255,179,0,0) 100%);
  box-shadow: 0 0 80rpx rgba(255,235,59,0.6), 0 0 160rpx rgba(255,235,59,0.25);
  animation: sunGlow 3s ease-in-out infinite alternate;
}
@keyframes sunGlow {
  from { transform: scale(1); box-shadow: 0 0 80rpx rgba(255,235,59,0.6); }
  to   { transform: scale(1.08); box-shadow: 0 0 120rpx rgba(255,235,59,0.8); }
}

/* ── 白云 ── */
.sm-cloud {
  position: absolute;
  height: 36rpx;
  background: rgba(255,255,255,0.92);
  border-radius: 36rpx;
}
.sm-cloud::before {
  content: '';
  position: absolute;
  top: -16rpx; left: 20%;
  width: 42rpx; height: 42rpx;
  background: rgba(255,255,255,0.92);
  border-radius: 50%;
}
.sm-cloud::after {
  content: '';
  position: absolute;
  top: -10rpx; right: 18%;
  width: 30rpx; height: 30rpx;
  background: rgba(255,255,255,0.92);
  border-radius: 50%;
}
.sm-c1 { top: 70rpx; left: -140rpx; width: 100rpx; animation: cloudDrift 22s linear infinite; }
.sm-c2 { top: 135rpx; left: -200rpx; width: 76rpx; height: 28rpx; animation: cloudDrift 28s linear infinite 7s; opacity: 0.8; }

@keyframes cloudDrift {
  from { transform: translateX(0); }
  to   { transform: translateX(1050rpx); }
}

/* ── 海鸥 ── */
.sm-gull {
  position: absolute;
  width: 28rpx; height: 10rpx;
  border-top: 3rpx solid #546e7a;
  border-radius: 60% 60% 0 0;
  background: transparent;
}
.sm-g1 { top: 65rpx;  left: -30rpx; animation: gullFly1 10s linear infinite; }
.sm-g2 { top: 100rpx; left: -50rpx; animation: gullFly2 13s linear infinite 3s; width: 22rpx; }
.sm-g3 { top: 50rpx;  left: -40rpx; animation: gullFly3 9s linear infinite 6s; width: 24rpx; }

@keyframes gullFly1 {
  from { transform: translateX(0) translateY(0); }
  to   { transform: translateX(950rpx) translateY(-25rpx); }
}
@keyframes gullFly2 {
  from { transform: translateX(0) translateY(0); }
  to   { transform: translateX(1000rpx) translateY(18rpx); }
}
@keyframes gullFly3 {
  from { transform: translateX(0) translateY(0); }
  to   { transform: translateX(920rpx) translateY(-12rpx); }
}

/* ── 大海 ── */
.sm-sea {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  height: 175rpx;
  z-index: 0;
  background: linear-gradient(to bottom, #64b5f6 0%, #42a5f5 18%, #1e88e5 45%, #1565c0 72%, #0d47a1 100%);
}
/* 海面波光 */
.sm-sea-glint {
  position: absolute;
  bottom: 55rpx; left: 0; right: 0;
  height: 28rpx;
  z-index: 2;
  background: linear-gradient(90deg, transparent 0%, rgba(255,255,255,0.22) 35%, rgba(255,255,255,0.38) 50%, rgba(255,255,255,0.2) 65%, transparent 100%);
  animation: seaGlint 4s ease-in-out infinite;
  pointer-events: none;
}
@keyframes seaGlint {
  0%, 100% { opacity: 0.35; transform: translateX(-8%); }
  50%      { opacity: 0.85; transform: translateX(8%); }
}

/* ── 帆船（海面由右向左） ── */
.sm-sailboat {
  position: absolute;
  bottom: 98rpx;
  left: 100%;
  width: 56rpx;
  height: 62rpx;
  z-index: 4;
  animation: sailboatDrift 20s linear infinite;
  transform-origin: center bottom;
}
.sm-boat-hull {
  position: absolute;
  bottom: 0; left: 4rpx;
  width: 48rpx; height: 16rpx;
  background: linear-gradient(to bottom, #a1887f, #6d4c41);
  border-radius: 4rpx 4rpx 50% 50%;
  box-shadow: inset 0 2rpx 0 rgba(255,255,255,0.12), 0 3rpx 6rpx rgba(0,0,0,0.2);
}
.sm-boat-mast {
  position: absolute;
  bottom: 14rpx; left: 26rpx;
  width: 3rpx; height: 40rpx;
  background: linear-gradient(to right, #3e2723, #5d4037);
  border-radius: 2rpx;
}
.sm-sail-main {
  position: absolute;
  bottom: 22rpx; left: 28rpx;
  width: 0; height: 0;
  border-bottom: 32rpx solid #eceff1;
  border-right: 22rpx solid transparent;
}
.sm-sail-jib {
  position: absolute;
  bottom: 24rpx; left: 8rpx;
  width: 0; height: 0;
  border-bottom: 24rpx solid #fafafa;
  border-left: 14rpx solid transparent;
  opacity: 0.95;
}

@keyframes sailboatDrift {
  0%   { transform: translateX(0) translateY(0) rotate(-2deg); }
  20%  { transform: translateX(-200rpx) translateY(-5rpx) rotate(1.5deg); }
  40%  { transform: translateX(-400rpx) translateY(0) rotate(-1deg); }
  60%  { transform: translateX(-600rpx) translateY(-4rpx) rotate(2deg); }
  80%  { transform: translateX(-800rpx) translateY(-2rpx) rotate(-1.5deg); }
  100% { transform: translateX(-1050rpx) translateY(0) rotate(-2deg); }
}

/* ── 海浪 ── */
.sm-wave {
  position: absolute;
  left: -10%; right: -10%;
  height: 28rpx;
  border-radius: 100% 100% 0 0 / 28rpx 28rpx 0 0;
}
.sm-w1 { bottom: 162rpx; z-index: 3; background: rgba(187,222,253,0.55); animation: waveRoll1 3s ease-in-out infinite; }
