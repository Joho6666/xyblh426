@keyframes snowDrift {
  0%   { transform: translateY(0) translateX(0); opacity: 0; }
  4%   { opacity: 0.9; }
  25%  { transform: translateY(28vh) translateX(15rpx); }
  50%  { transform: translateY(55vh) translateX(-10rpx); opacity: 0.8; }
