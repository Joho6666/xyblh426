/* ==============================================
   前景内容 — 表单 + 季节主题色
   ============================================== */

.login-content {
  position: relative;
  z-index: 10;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 48rpx 0;
  animation: contentUp 0.8s ease both;
  isolation: isolate;
  transform: translateZ(0);
}
@keyframes contentUp {
  from { opacity: 0; transform: translateY(30rpx); }
  to   { opacity: 1; transform: translateY(0); }
}

/* ── 季节指示器 ── */
.season-indicator {
  display: flex;
  gap: 24rpx;
  margin-bottom: 36rpx;
}
.season-dot {
  font-size: 22rpx;
  padding: 6rpx 18rpx;
  border-radius: 20rpx;
  background: rgba(255,255,255,0.55);
  color: rgba(0,0,0,0.35);
  transition: all 0.6s ease;
  backdrop-filter: blur(6px);
  -webkit-backdrop-filter: blur(6px);
  font-weight: 500;
}
.dot-active {
  color: #fff;
  font-weight: 600;
  transform: scale(1.1);
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.12);
}
.season-spring .dot-active { background: linear-gradient(135deg, #f48fb1, #e91e63); }
.season-summer .dot-active { background: linear-gradient(135deg, #4fc3f7, #0288d1); }
.season-autumn .dot-active { background: linear-gradient(135deg, #ffb74d, #e65100); }
.season-winter .dot-active { background: linear-gradient(135deg, #90caf9, #5c6bc0); }

/* ── Logo ── */
.login-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 40rpx;
}
.logo-ring {
  width: 180rpx; height: 180rpx;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 22rpx;
  transition: all 1s ease;
}
.season-spring .logo-ring {
  background: linear-gradient(135deg, rgba(248,187,208,0.6), rgba(200,230,201,0.4));
  box-shadow: 0 8rpx 40rpx rgba(233,30,99,0.3);
  animation: logoSpring 3s ease-in-out infinite;
}
.season-summer .logo-ring {
  background: linear-gradient(135deg, rgba(255,241,118,0.5), rgba(129,212,250,0.4));
  box-shadow: 0 8rpx 40rpx rgba(255,193,7,0.4);
  animation: logoSummer 2.5s ease-in-out infinite;
}
.season-autumn .logo-ring {
  background: linear-gradient(135deg, rgba(255,183,77,0.6), rgba(239,108,0,0.3));
  box-shadow: 0 8rpx 40rpx rgba(230,81,0,0.3);
  animation: logoAutumn 4s ease-in-out infinite;
}
.season-winter .logo-ring {
  background: linear-gradient(135deg, rgba(187,222,251,0.6), rgba(206,147,216,0.3));
  box-shadow: 0 8rpx 40rpx rgba(92,107,192,0.3);
  animation: logoWinter 2s ease-in-out infinite;
}

@keyframes logoSpring {
  0%, 100% { transform: scale(1); }
  50%      { transform: scale(1.06); }
}
@keyframes logoSummer {
  0%, 100% { transform: scale(1); box-shadow: 0 8rpx 40rpx rgba(255,193,7,0.4); }
  50%      { transform: scale(1.04) rotate(2deg); box-shadow: 0 12rpx 60rpx rgba(255,193,7,0.6); }
}
@keyframes logoAutumn {
  0%, 100% { transform: rotate(0deg); }
  25%      { transform: rotate(2deg); }
  75%      { transform: rotate(-2deg); }
}
@keyframes logoWinter {
  0%, 100% { transform: translateY(0); }
  25%      { transform: translateY(-3rpx); }
  75%      { transform: translateY(3rpx); }
}

.logo-inner {
  width: 140rpx; height: 140rpx;
  border-radius: 30rpx;
  overflow: hidden;
  background: #fff;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.08);
}
.login-logo-img { width: 100%; height: 100%; }

/* ── 标题 ── */
.login-title {
  font-size: 42rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  margin-bottom: 10rpx;
  transition: color 1s ease;
}
.season-spring .login-title { color: #c2185b; }
.season-summer .login-title { color: #01579b; }
.season-autumn .login-title { color: #bf360c; }
.season-winter .login-title { color: #283593; }

.login-subtitle {
  font-size: 26rpx;
  font-weight: 400;
  transition: color 1s ease;
}
.season-spring .login-subtitle { color: #ad1457; }
.season-summer .login-subtitle { color: #0277bd; }
.season-autumn .login-subtitle { color: #d84315; }
.season-winter .login-subtitle { color: #3949ab; }

/* ── 表单卡片 ── */
.login-form-card {
  width: 100%;
  border-radius: 32rpx;
  padding: 4rpx;
  transition: all 1s ease;
  overflow: visible;
}
.season-spring .login-form-card {
  background: linear-gradient(135deg, rgba(248,187,208,0.5), rgba(200,230,201,0.3));
  box-shadow: 0 16rpx 48rpx rgba(233,30,99,0.1);
}
.season-summer .login-form-card {
  background: linear-gradient(135deg, rgba(129,212,250,0.4), rgba(255,241,118,0.3));
  box-shadow: 0 16rpx 48rpx rgba(2,136,209,0.1);
}
.season-autumn .login-form-card {
  background: linear-gradient(135deg, rgba(255,183,77,0.4), rgba(255,204,188,0.3));
  box-shadow: 0 16rpx 48rpx rgba(230,81,0,0.1);
}
.season-winter .login-form-card {
  background: linear-gradient(135deg, rgba(187,222,251,0.4), rgba(225,190,231,0.3));
  box-shadow: 0 16rpx 48rpx rgba(92,107,192,0.1);
}

.login-form {
  background: rgba(255,255,255,0.82);
  backdrop-filter: blur(24px) saturate(150%);
  -webkit-backdrop-filter: blur(24px) saturate(150%);
  border-radius: 30rpx;
  padding: 44rpx 40rpx 32rpx;
  overflow: visible;
}

.login-quick-hint {
  margin: -8rpx 0 28rpx;
  padding: 16rpx 20rpx;
  font-size: 24rpx;
  line-height: 1.55;
  color: rgba(0,0,0,0.55);
  background: rgba(255,255,255,0.65);
  border-radius: 16rpx;
  border: 1rpx solid rgba(0,0,0,0.06);
}
.season-spring .login-quick-hint { color: rgba(136,14,79,0.75); background: rgba(252,228,236,0.45); }
.season-summer .login-quick-hint { color: rgba(1,87,155,0.75); background: rgba(227,242,253,0.5); }
.season-autumn .login-quick-hint { color: rgba(191,54,12,0.75); background: rgba(255,243,224,0.55); }
.season-winter .login-quick-hint { color: rgba(26,35,126,0.72); background: rgba(237,231,246,0.45); }

/* ── 头像（透明按钮覆盖，避免原生 button 遮罩；光环仅用浅色阴影） ── */
.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 32rpx;
  position: relative;
  z-index: 2;
}
.avatar-stack {
  position: relative;
  width: 168rpx;
  height: 168rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.avatar-hit {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 168rpx;
  height: 168rpx;
  margin-left: -84rpx;
  margin-top: -84rpx;
  padding: 0;
  border: 0 !important;
  border-width: 0 !important;
  border-style: none !important;
  border-color: transparent !important;
  border-radius: 50%;
  min-height: 0;
  line-height: normal;
  color: transparent;
  background: transparent !important;
  opacity: 0;
  overflow: hidden;
  z-index: 6;
}
/* 微信 button 默认用 ::after 画线框，必须压掉否则会出现黑/灰矩形 */
.avatar-hit::after {
  display: block !important;
  border: none !important;
  width: 0 !important;
  height: 0 !important;
  padding: 0 !important;
  margin: 0 !important;
  transform: scale(0);
  opacity: 0;
}

.avatar-ring {
  width: 144rpx;
  height: 144rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  overflow: visible;
  transition: transform 0.8s ease;
  box-sizing: border-box;
}
.season-spring .avatar-ring {
  background: linear-gradient(145deg, #fce4ec, #c8e6c9);
  box-shadow: 0 0 0 4rpx rgba(255,255,255,0.85), 0 6rpx 28rpx rgba(233,30,99,0.28);
  animation: ringPulseSpring 3s ease-in-out infinite;
}
.season-summer .avatar-ring {
  background: linear-gradient(145deg, #fff9c4, #81d4fa);
  box-shadow: 0 0 0 4rpx rgba(255,255,255,0.9), 0 6rpx 28rpx rgba(3,155,229,0.3);
  animation: ringPulseSummer 2.6s ease-in-out infinite;
}
.season-autumn .avatar-ring {
  background: linear-gradient(145deg, #ffe0b2, #ff9800);
  box-shadow: 0 0 0 4rpx rgba(255,255,255,0.88), 0 6rpx 28rpx rgba(230,81,0,0.28);
  animation: ringPulseAutumn 3.2s ease-in-out infinite;
}
.season-winter .avatar-ring {
  background: linear-gradient(145deg, #e3f2fd, #e1bee7);
  box-shadow: 0 0 0 4rpx rgba(255,255,255,0.92), 0 6rpx 28rpx rgba(92,107,192,0.28);
  animation: ringPulseWinter 2.4s ease-in-out infinite;
}

@keyframes ringPulseSpring {
  0%, 100% { transform: scale(1); box-shadow: 0 0 0 4rpx rgba(255,255,255,0.85), 0 6rpx 28rpx rgba(233,30,99,0.28); }
  50%      { transform: scale(1.03); box-shadow: 0 0 0 4rpx rgba(255,255,255,0.95), 0 10rpx 40rpx rgba(233,30,99,0.38); }
}
@keyframes ringPulseSummer {
  0%, 100% { transform: scale(1); box-shadow: 0 0 0 4rpx rgba(255,255,255,0.9), 0 6rpx 28rpx rgba(3,155,229,0.3); }
  50%      { transform: scale(1.03); box-shadow: 0 0 0 4rpx rgba(255,255,255,1), 0 10rpx 40rpx rgba(255,193,7,0.35); }
}
@keyframes ringPulseAutumn {
  0%, 100% { transform: scale(1); box-shadow: 0 0 0 4rpx rgba(255,255,255,0.88), 0 6rpx 28rpx rgba(230,81,0,0.28); }
  50%      { transform: scale(1.03); box-shadow: 0 0 0 4rpx rgba(255,255,255,0.98), 0 10rpx 40rpx rgba(255,152,0,0.32); }
}
@keyframes ringPulseWinter {
  0%, 100% { transform: scale(1); box-shadow: 0 0 0 4rpx rgba(255,255,255,0.92), 0 6rpx 28rpx rgba(92,107,192,0.28); }
  33%      { transform: scale(1.025); box-shadow: 0 0 0 4rpx rgba(255,255,255,1), 0 10rpx 38rpx rgba(144,202,249,0.4); }
  66%      { transform: scale(1.02); box-shadow: 0 0 0 4rpx rgba(255,255,255,0.95), 0 8rpx 36rpx rgba(206,147,216,0.35); }
}

.avatar-preview {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid #fff;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.08);
  display: block;
}

.avatar-edit-badge {
  margin-top: 12rpx;
  font-size: 22rpx;
  transition: color 0.8s ease;
}
.season-spring .avatar-edit-badge { color: #c2185b; }
.season-summer .avatar-edit-badge { color: #0277bd; }
.season-autumn .avatar-edit-badge { color: #d84315; }
.season-winter .avatar-edit-badge { color: #3949ab; }

/* ── 昵称 ── */
.nickname-section { margin-bottom: 32rpx; }
.form-label {
  font-size: 26rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
  display: block;
  transition: color 0.8s ease;
}
.season-spring .form-label { color: #880e4f; }
.season-summer .form-label { color: #01579b; }
.season-autumn .form-label { color: #bf360c; }
.season-winter .form-label { color: #1a237e; }

.nickname-input {
  width: 100%;
  height: 88rpx;
  border-radius: 20rpx;
  padding: 0 28rpx;
  font-size: 30rpx;
  box-sizing: border-box;
  transition: all 0.8s ease;
}
.season-spring .nickname-input { background: rgba(248,187,208,0.12); border: 2rpx solid rgba(233,30,99,0.18); color: #880e4f; }
.season-summer .nickname-input { background: rgba(129,212,250,0.12); border: 2rpx solid rgba(2,136,209,0.18); color: #01579b; }
.season-autumn .nickname-input { background: rgba(255,183,77,0.12); border: 2rpx solid rgba(239,108,0,0.18); color: #bf360c; }
.season-winter .nickname-input { background: rgba(187,222,251,0.15); border: 2rpx solid rgba(92,107,192,0.18); color: #1a237e; }

/* ── 登录按钮 ── */
.login-btn {
  width: 100%;
  height: 92rpx;
  border-radius: 46rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 18rpx;
  transition: all 0.8s ease;
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
}
.season-spring .login-btn { background: linear-gradient(135deg, #ec407a, #f48fb1); box-shadow: 0 8rpx 28rpx rgba(233,30,99,0.3); }
.season-summer .login-btn { background: linear-gradient(135deg, #039be5, #4fc3f7); box-shadow: 0 8rpx 28rpx rgba(2,136,209,0.3); }
.season-autumn .login-btn { background: linear-gradient(135deg, #ef6c00, #ffb74d); box-shadow: 0 8rpx 28rpx rgba(230,81,0,0.3); }
.season-winter .login-btn { background: linear-gradient(135deg, #5c6bc0, #90caf9); box-shadow: 0 8rpx 28rpx rgba(92,107,192,0.3); }

.login-btn:active { transform: scale(0.97); opacity: 0.9; }
.btn-loading { opacity: 0.65; }

/* ── 跳过 ── */
.skip-btn {
  text-align: center;
  padding: 14rpx 0;
  font-size: 26rpx;
  transition: color 0.8s ease;
}
.season-spring .skip-btn { color: #ad1457; }
.season-summer .skip-btn { color: #0277bd; }
.season-autumn .skip-btn { color: #d84315; }
.season-winter .skip-btn { color: #3949ab; }
.skip-btn:active { opacity: 0.6; }

/* ── 协议勾选（须主动勾选，禁止默认同意） ── */
.login-terms-row {
  padding: 8rpx 0 4rpx;
}
.terms-label {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  font-size: 24rpx;
  line-height: 1.45;
}
.season-spring .terms-text { color: rgba(136,14,79,0.85); }
.season-summer .terms-text { color: rgba(1,87,155,0.85); }
.season-autumn .terms-text { color: rgba(191,54,12,0.85); }
.season-winter .terms-text { color: rgba(26,35,126,0.85); }
.terms-link {
  color: #426089;
  text-decoration: underline;
}

/* ── 底部 ── */
.login-footer {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  text-align: center;
  padding: 22rpx 0;
  padding-bottom: calc(22rpx + env(safe-area-inset-bottom));
  z-index: 11;
}
.footer-text {
  font-size: 22rpx;
  transition: color 0.8s ease;
}
.season-spring .footer-text { color: rgba(136,14,79,0.5); }
.season-summer .footer-text { color: rgba(1,87,155,0.5); }
.season-autumn .footer-text { color: rgba(191,54,12,0.5); }
.season-winter .footer-text { color: rgba(26,35,126,0.5); }

.footer-link {
  font-size: 22rpx;
  margin-left: 0;
  transition: color 0.8s ease;
}
.season-spring .footer-link { color: #c2185b; }
.season-summer .footer-link { color: #0277bd; }
.season-autumn .footer-link { color: #e65100; }
.season-winter .footer-link { color: #3949ab; }
