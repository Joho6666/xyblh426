/* pages/market-detail/market-detail.wxss — 与全局 Campus Blue 令牌对齐 */

.page {
  background: var(--surface);
  min-height: 100vh;
  padding-bottom: 160rpx;
  box-sizing: border-box;
}

.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 400rpx;
  color: var(--outline-variant);
  font-size: var(--text-sm);
}

.detail-empty-state {
  min-height: 100vh;
  padding: 180rpx 48rpx 0;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
  text-align: center;
  background: var(--surface);
}

.detail-empty-icon { font-size: 96rpx; line-height: 1; }
.detail-empty-title { font-size: var(--text-lg); font-weight: 800; color: var(--on-surface); letter-spacing: -0.5rpx; }
.detail-empty-sub { font-size: var(--text-sm); color: var(--on-surface-variant); line-height: 1.7; max-width: 560rpx; }
.detail-empty-btn {
  margin-top: 12rpx;
  padding: 20rpx 44rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, var(--primary), var(--primary-dim));
  color: var(--on-primary);
  font-size: var(--text-sm);
  font-weight: 700;
  box-shadow: 0 12rpx 32rpx rgba(66, 96, 137, 0.28);
}

/* 轮播图 */
.image-swiper {
  width: 100%;
  height: 640rpx;
  background: var(--on-surface);
}
.swiper-img { width: 100%; height: 100%; }

/* 内容区：左右留白 + 圆角卡片叠在背景上 */
.price-card,
.desc-card,
.seller-card,
.comment-card,
.owner-manage-card {
  margin: 0 24rpx 20rpx;
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-card);
  box-sizing: border-box;
}

.price-card {
  background: var(--surface-container-lowest);
  padding: 36rpx 32rpx 32rpx;
  margin-top: -28rpx;
  position: relative;
  z-index: 1;
}

.price-row { display: flex; align-items: baseline; gap: 16rpx; margin-bottom: 12rpx; }
.price-main { font-size: 52rpx; font-weight: 800; color: var(--accent); letter-spacing: -1rpx; }
.price-original { font-size: var(--text-sm); color: var(--outline-variant); text-decoration: line-through; }
.goods-title {
  font-size: var(--text-lg);
  font-weight: 800;
  color: var(--on-surface);
  line-height: 1.45;
  letter-spacing: -0.5rpx;
  margin-bottom: 20rpx;
}
.tag-row { display: flex; gap: 12rpx; flex-wrap: wrap; }
.tag {
  font-size: var(--text-xs);
  color: var(--on-surface-variant);
  background: var(--surface-container-low);
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  font-weight: 500;
}
.tag.trade { color: #c2410c; background: var(--secondary-container); }
.tag.bargain { color: #15803d; background: rgba(34, 197, 94, 0.12); }
.tag.category { color: var(--on-primary-container); background: var(--primary-container); }

.desc-card { background: var(--surface-container-lowest); padding: 32rpx; }
.desc-label { font-size: var(--text-body); font-weight: 700; color: var(--on-surface); display: block; margin-bottom: 16rpx; }
.desc-text { font-size: var(--text-body); color: var(--on-surface-variant); line-height: 1.75; }

.seller-card { background: var(--surface-container-lowest); padding: 28rpx 32rpx; display: flex; align-items: center; gap: 20rpx; }
.seller-avatar { width: 96rpx; height: 96rpx; border-radius: 50%; flex-shrink: 0; border: 3rpx solid var(--surface-container); }
.seller-info { flex: 1; min-width: 0; }
.seller-name { font-size: var(--text-body); font-weight: 700; color: var(--on-surface); display: block; }
.seller-id { font-size: var(--text-xs); color: var(--outline-variant); margin-top: 6rpx; display: block; }
.seller-time { font-size: var(--text-xs); color: var(--outline-variant); margin-top: 4rpx; }
.seller-arrow { font-size: 32rpx; color: var(--outline-variant); }

.owner-manage-card {
  background: var(--secondary-container);
  padding: 28rpx 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}
.owner-manage-text {
  flex: 1;
  font-size: var(--text-sm);
  color: var(--on-secondary-container);
  line-height: 1.6;
}
.owner-manage-btn {
  flex-shrink: 0;
  padding: 18rpx 28rpx;
  border-radius: 999rpx;
  background: var(--error);
  color: var(--on-primary);
  font-size: var(--text-sm);
  font-weight: 700;
}

.comment-card {
  background: var(--surface-container-lowest);
  padding: 28rpx 32rpx 36rpx;
}

.comment-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}
.comment-title { font-size: var(--text-md); font-weight: 800; color: var(--on-surface); }
.comment-count { font-size: var(--text-xs); color: var(--outline-variant); }

.comment-editor {
  display: flex;
  flex-direction: column;
  align-items: stretch;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.reply-banner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 16rpx 20rpx;
  border-radius: var(--radius-sm);
  background: var(--info-container);
}
.reply-banner-text { font-size: var(--text-xs); color: var(--on-info-container); font-weight: 600; }
.reply-banner-cancel { font-size: var(--text-xs); color: var(--on-surface-variant); }

.comment-editor-row { display: flex; align-items: center; gap: 16rpx; }

.comment-input {
  flex: 1;
  height: 80rpx;
  background: var(--surface-container-low);
  border-radius: 999rpx;
  padding: 0 28rpx;
  font-size: var(--text-sm);
  color: var(--on-surface);
}

.comment-send-btn {
  flex-shrink: 0;
  padding: 20rpx 32rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, var(--primary), var(--primary-dim));
  color: var(--on-primary);
  font-size: var(--text-sm);
  font-weight: 700;
  box-shadow: 0 8rpx 24rpx rgba(66, 96, 137, 0.22);
}

.comment-send-btn-disabled { opacity: 0.55; }

.comment-empty {
  padding: 32rpx 0 12rpx;
  text-align: center;
  font-size: var(--text-sm);
  color: var(--outline-variant);
}

.comment-list { display: flex; flex-direction: column; gap: 28rpx; }
.comment-item { display: flex; gap: 16rpx; }
.comment-avatar { width: 72rpx; height: 72rpx; border-radius: 50%; flex-shrink: 0; }
.comment-body { flex: 1; min-width: 0; }
.comment-top { display: flex; align-items: center; gap: 12rpx; margin-bottom: 8rpx; flex-wrap: wrap; }
.comment-name { font-size: var(--text-sm); font-weight: 700; color: var(--on-surface); }
.comment-user-id {
  font-size: 20rpx;
  color: var(--on-primary-container);
  background: var(--primary-container);
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
}
.comment-time { margin-left: auto; font-size: 20rpx; color: var(--outline-variant); }
.comment-content { font-size: var(--text-sm); color: var(--on-surface-variant); line-height: 1.75; word-break: break-word; }
.comment-reply-quote { margin-bottom: 8rpx; }
.comment-reply-label {
  font-size: var(--text-xs);
  color: var(--primary);
  background: var(--primary-container);
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
}
.comment-reply-btn {
  display: inline-block;
  margin-top: 8rpx;
  font-size: var(--text-xs);
  color: var(--primary);
  font-weight: 700;
}
.comment-replies {
  margin-top: 18rpx;
  padding-left: 16rpx;
  border-left: 4rpx solid var(--surface-container-high);
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}
.comment-reply-item { display: flex; gap: 14rpx; }
.comment-reply-avatar { width: 56rpx; height: 56rpx; border-radius: 50%; flex-shrink: 0; }
.comment-reply-body { flex: 1; min-width: 0; }

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.96);
  backdrop-filter: blur(12px);
  border-top: 1rpx solid var(--hairline);
  z-index: 100;
  box-sizing: border-box;
  box-shadow: 0 -8rpx 32rpx rgba(44, 51, 56, 0.04);
}
.bar-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 2rpx;
  background: none;
  border: none;
  padding: 8rpx 12rpx;
  line-height: 1;
  font-size: inherit;
  flex-shrink: 0;
}
.bar-btn::after { border: none; }
.bar-btn-wide {
  flex: 1;
  min-width: 0;
  background: var(--surface-container-low);
  border-radius: var(--radius-sm);
  padding: 16rpx 20rpx;
}
.bar-icon { font-size: 36rpx; }
.bar-label { font-size: 20rpx; color: var(--outline-variant); }
.bar-right { flex-shrink: 0; min-width: 200rpx; display: flex; justify-content: flex-end; }
.chat-btn {
  min-width: 200rpx;
  text-align: center;
  padding: 24rpx 32rpx;
  background: linear-gradient(135deg, var(--accent), #b03d52);
  color: #fff;
  font-size: var(--text-body);
  font-weight: 800;
  border-radius: 999rpx;
  box-shadow: 0 10rpx 28rpx rgba(201, 74, 98, 0.28);
}
.chat-btn-owner {
  background: var(--surface-container-high);
  color: var(--on-surface-variant);
  box-shadow: none;
  font-weight: 600;
}

/* 分享面板 */
.md-share-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 1000;
  background: rgba(44, 51, 56, 0.45);
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
}
.md-share-sheet {
  background: var(--surface-container-lowest);
  border-radius: var(--radius-lg) var(--radius-lg) 0 0;
  padding: 12rpx 24rpx calc(24rpx + env(safe-area-inset-bottom));
  padding-top: 16rpx;
}
.md-share-grabber {
  width: 64rpx;
  height: 8rpx;
  border-radius: 4rpx;
  background: var(--surface-container-high);
  margin: 0 auto 20rpx;
}
.md-share-title {
  display: block;
  text-align: center;
  font-size: var(--text-sm);
  font-weight: 600;
  color: var(--outline-variant);
  margin-bottom: 20rpx;
}
.md-share-row {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 28rpx 24rpx;
  margin-bottom: 12rpx;
  border-radius: var(--radius-sm);
  font-size: var(--text-md);
  font-weight: 600;
}
.md-share-row-primary {
  background: linear-gradient(135deg, var(--primary), var(--primary-dim));
  color: var(--on-primary);
  box-shadow: 0 8rpx 24rpx rgba(66, 96, 137, 0.22);
}
.md-share-row-wx {
  background: var(--surface-container-low);
  color: var(--on-surface);
  border: none;
  line-height: 1.4;
}
.md-share-row-wx::after { display: none; }
.md-share-cancel {
  background: transparent;
  color: var(--outline-variant);
  margin-bottom: 0;
  font-weight: 500;
}
