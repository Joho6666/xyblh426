/* pages/market-post/market-post.wxss — 与全局主题一致 */

.page {
  background: var(--surface);
  min-height: 100vh;
  padding-bottom: 240rpx;
}

.draft-banner {
  margin: 20rpx 24rpx;
  padding: 20rpx 24rpx;
  border-radius: var(--radius-md);
  background: var(--success-container);
  color: var(--on-success-container);
  font-size: var(--text-sm);
  font-weight: 600;
}

/* ===== 图片上传 ===== */
.image-section {
  background: var(--surface-container-lowest);
  padding: 28rpx 24rpx;
  margin: 0 24rpx 20rpx;
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-card);
  box-sizing: border-box;
}
.image-scroll { white-space: nowrap; }
.img-item {
  display: inline-block;
  width: 200rpx;
  height: 200rpx;
  border-radius: var(--radius-sm);
  overflow: hidden;
  margin-right: 16rpx;
  position: relative;
  vertical-align: top;
}
.img-preview { width: 100%; height: 100%; }
.img-remove {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 44rpx;
  height: 44rpx;
  background: rgba(44, 51, 56, 0.55);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 28rpx;
}
.img-cover-badge {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(44, 51, 56, 0.55);
  color: #fff;
  font-size: 20rpx;
  text-align: center;
  padding: 6rpx 0;
}
.img-add {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 200rpx;
  height: 200rpx;
  border-radius: var(--radius-sm);
  border: 3rpx dashed var(--outline-variant);
  gap: 8rpx;
  vertical-align: top;
  background: var(--surface-container-low);
}
.add-icon { font-size: 48rpx; opacity: 0.85; }
.add-text { font-size: var(--text-xs); color: var(--outline-variant); }

/* ===== 表单区 ===== */
.form-section {
  background: var(--surface-container-lowest);
  padding: 32rpx;
  margin: 0 24rpx 20rpx;
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-card);
  box-sizing: border-box;
}
.form-item { margin-bottom: 24rpx; }
.form-item:last-child { margin-bottom: 0; }
.title-input {
  width: 100%;
  font-size: var(--text-lg);
  font-weight: 800;
  color: var(--on-surface);
  min-height: 60rpx;
  letter-spacing: -0.5rpx;
}
.desc-input {
  width: 100%;
  font-size: var(--text-body);
  color: var(--on-surface-variant);
  min-height: 160rpx;
  line-height: 1.75;
}

/* ===== 价格 ===== */
.price-section {
  background: var(--surface-container-lowest);
  padding: 32rpx;
  margin: 0 24rpx 20rpx;
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-card);
  box-sizing: border-box;
}
.price-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18rpx 0;
  border-bottom: 1rpx solid var(--surface-container);
}
.price-row:last-child { border-bottom: none; }
.price-label { font-size: var(--text-body); color: var(--on-surface); font-weight: 600; }
.price-input-wrap { display: flex; align-items: baseline; gap: 4rpx; }
.price-symbol { font-size: var(--text-lg); font-weight: 800; color: var(--accent); }
.price-symbol.sub { font-size: 26rpx; color: var(--outline-variant); }
.price-input {
  width: 200rpx;
  text-align: right;
  font-size: var(--text-lg);
  font-weight: 700;
  color: var(--accent);
}
.price-row:last-child .price-input {
  color: var(--outline-variant);
  font-weight: 500;
  font-size: var(--text-body);
}

/* ===== 选项区 ===== */
.option-section {
  background: var(--surface-container-lowest);
  padding: 16rpx 32rpx;
  margin: 0 24rpx 20rpx;
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-card);
  box-sizing: border-box;
}
.option-row { padding: 24rpx 0; border-bottom: 1rpx solid var(--surface-container); }
.option-row:last-child { border-bottom: none; }
.option-label {
  font-size: var(--text-body);
  color: var(--on-surface);
  font-weight: 600;
  display: block;
  margin-bottom: 16rpx;
}
.option-value-wrap { display: flex; align-items: center; justify-content: flex-end; margin-top: -52rpx; }
.option-value { font-size: var(--text-body); color: var(--on-surface); }
.option-value.placeholder { color: var(--outline-variant); }
.arrow { font-size: var(--text-lg); color: var(--outline-variant); margin-left: 8rpx; }

.condition-tags { display: flex; gap: 16rpx; flex-wrap: wrap; }
.cond-tag {
  font-size: var(--text-sm);
  color: var(--on-surface-variant);
  background: var(--surface-container-low);
  padding: 14rpx 32rpx;
  border-radius: 999rpx;
  transition: all 0.2s;
}
.cond-active {
  background: linear-gradient(135deg, var(--primary), var(--primary-dim));
  color: var(--on-primary);
  font-weight: 700;
  box-shadow: 0 8rpx 20rpx rgba(66, 96, 137, 0.2);
}

/* ===== 发布按钮 ===== */
.publish-section { padding: 24rpx 28rpx; }
.draft-tools {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}
.draft-btn {
  padding: 14rpx 28rpx;
  border-radius: 999rpx;
  background: var(--surface-container-lowest);
  color: var(--primary);
  font-size: var(--text-sm);
  font-weight: 600;
  box-shadow: var(--shadow-card);
}
.draft-tip { font-size: var(--text-xs); color: var(--outline-variant); }
.publish-btn {
  width: 100%;
  height: 100rpx;
  background: linear-gradient(135deg, var(--primary), var(--primary-dim));
  color: var(--on-primary);
  font-size: var(--text-lg);
  font-weight: 700;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  box-shadow: 0 14rpx 40rpx rgba(66, 96, 137, 0.3);
}
.publish-btn.disabled { opacity: 0.5; }
.publish-btn::after { border: none; }

/* ===== 分类选择器 ===== */
.picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(44, 51, 56, 0.45);
  z-index: 200;
  display: none;
}
.picker-mask.show { display: block; }
.picker-panel {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: var(--surface-container-lowest);
  border-radius: var(--radius-lg) var(--radius-lg) 0 0;
  padding: 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
}
.picker-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 32rpx; }
.picker-title { font-size: var(--text-lg); font-weight: 800; color: var(--on-surface); }
.picker-close { font-size: var(--text-lg); color: var(--outline-variant); padding: 8rpx; }
.picker-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16rpx; }
.picker-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 20rpx 0;
  border-radius: var(--radius-sm);
  transition: all 0.2s;
}
.picker-active { background: var(--accent-soft); }
.picker-emoji { font-size: 40rpx; }
.picker-name { font-size: var(--text-xs); color: var(--on-surface-variant); font-weight: 500; }
.picker-active .picker-name { color: var(--accent); font-weight: 700; }
