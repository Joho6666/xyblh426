.page {
  min-height: 100vh;
  width: 100%;
  overflow-x: hidden;
  box-sizing: border-box;
  background: var(--surface);
}

.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: rgba(255, 255, 255, 0.88);
  backdrop-filter: saturate(180%) blur(20px);
  -webkit-backdrop-filter: saturate(180%) blur(20px);
  box-shadow: 0 4rpx 20rpx rgba(44, 51, 56, 0.04);
  box-sizing: border-box;
  transform: translateZ(0);
}

.nav-content {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 12rpx 24rpx 16rpx;
  box-sizing: border-box;
}

.nav-title {
  flex-shrink: 0;
  font-size: 36rpx;
  font-weight: 800;
  color: var(--primary);
  letter-spacing: -0.5rpx;
}

.nav-search {
  flex: 1;
  display: flex;
  align-items: center;
  min-width: 0;
  padding: 12rpx 22rpx;
  border-radius: 999rpx;
  background: var(--surface-container-low);
  border: 1rpx solid rgba(116, 124, 129, 0.08);
  box-sizing: border-box;
}

.search-icon {
  font-size: 24rpx;
  margin-right: 10rpx;
}

.search-input {
  flex: 1;
  min-width: 0;
  font-size: 26rpx;
  color: var(--on-surface);
}

.nav-search-clear {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: var(--surface-container);
  font-size: 22rpx;
  color: var(--on-surface-variant);
}

.cat-scroll {
  white-space: nowrap;
  padding: 18rpx 0 18rpx 24rpx;
  background: var(--surface-container-lowest);
  box-sizing: border-box;
}

.cat-track {
  display: inline-flex;
  align-items: center;
  gap: 12rpx;
  padding-right: 24rpx;
}

.page-hint {
  padding: 12rpx 24rpx 0;
  font-size: 22rpx;
  color: var(--outline-variant);
}

.market-disclaimer {
  margin: 12rpx 24rpx 8rpx;
  padding: 14rpx 20rpx;
  border-radius: 16rpx;
  background: var(--surface-container-low);
  font-size: 22rpx;
  line-height: 1.45;
  color: var(--on-surface-variant);
}

.cat-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  padding: 10rpx 24rpx;
  flex-shrink: 0;
  border-radius: 18rpx;
}

.cat-active {
  background: var(--primary-container);
}

.cat-emoji {
  font-size: 56rpx;
}

.cat-name {
  font-size: 22rpx;
  color: var(--on-surface-variant);
  font-weight: 600;
}

.cat-active .cat-name {
  color: var(--on-primary-container);
}

.waterfall {
  display: flex;
  gap: 12rpx;
  width: 100%;
  padding: 12rpx;
  box-sizing: border-box;
  align-items: flex-start;
}

.wf-col {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  will-change: transform;
}

.goods-card {
  overflow: hidden;
  border-radius: 28rpx;
  background: var(--surface-container-lowest);
  width: 100%;
  box-sizing: border-box;
  box-shadow: 0 12rpx 40rpx rgba(44, 51, 56, 0.07);
  transform: translateZ(0);
  backface-visibility: hidden;
}

.goods-card:active {
  transform: scale(0.985) translateZ(0);
  opacity: 0.98;
  transition: transform 0.12s ease, opacity 0.12s ease;
}

.goods-cover-wrap {
  position: relative;
  overflow: hidden;
  width: 100%;
  height: 280rpx;
  flex-shrink: 0;
  background: var(--surface-container-low);
}

.goods-media-skeleton {
  position: absolute;
  inset: 0;
  background: linear-gradient(90deg, var(--surface-container) 25%, var(--surface-container-low) 50%, var(--surface-container) 75%);
  background-size: 220% 100%;
  animation: marketShimmer 1.2s linear infinite, goodsSkeletonSafeHide 0s 2.5s forwards;
  z-index: 1;
}

.goods-skeleton-hidden {
  opacity: 0;
  pointer-events: none;
  transition: opacity 180ms ease;
  animation: none;
}

@keyframes goodsSkeletonSafeHide {
  to { opacity: 0; pointer-events: none; }
}

.goods-cover {
  display: block;
  width: 100%;
  height: 100%;
  opacity: 0;
  transition: opacity 220ms ease;
  animation: goodsCoverSafeShow 0s 2s forwards;
}

.goods-cover-ready {
  opacity: 1;
  animation: none;
}

@keyframes goodsCoverSafeShow {
  to { opacity: 1; }
}

@keyframes marketShimmer {
  0% {
    background-position: 100% 0;
  }
  100% {
    background-position: -100% 0;
  }
}

.goods-cover-empty {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 280rpx;
  flex-shrink: 0;
  color: var(--outline-variant);
  background: var(--surface-container-low);
  font-size: 24rpx;
}

.goods-info {
  padding: 16rpx 20rpx 20rpx;
  box-sizing: border-box;
}

.goods-title {
  display: -webkit-box;
  overflow: hidden;
  margin-bottom: 10rpx;
  font-size: 26rpx;
  line-height: 1.4;
  color: var(--on-surface);
  font-weight: 700;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.goods-price-row {
  display: flex;
  align-items: baseline;
  gap: 10rpx;
  margin-bottom: 12rpx;
}

.goods-price {
  font-size: 32rpx;
  font-weight: 800;
  color: var(--accent);
}

.goods-original {
  font-size: 22rpx;
  color: var(--outline-variant);
  text-decoration: line-through;
}

.goods-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  margin-bottom: 10rpx;
}

.goods-author {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.goods-avatar {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.goods-name {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 20rpx;
  color: var(--on-surface-variant);
}

.goods-want {
  flex-shrink: 0;
  font-size: 20rpx;
  color: var(--accent);
}

.goods-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.goods-tag {
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  background: var(--surface-container-low);
  color: var(--on-surface-variant);
  font-size: 20rpx;
}

.trade-tag {
  background: #fff7ed;
  color: #ea580c;
}

.load-status {
  padding: 40rpx 0;
  text-align: center;
}

.load-status.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-emoji {
  margin-bottom: 16rpx;
  font-size: 72rpx;
}

.load-text {
  font-size: 24rpx;
  color: var(--outline-variant);
}

.fab-btn {
  position: fixed;
  right: 32rpx;
  bottom: 200rpx;
  z-index: 50;
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  background: linear-gradient(145deg, var(--primary), var(--primary-dim));
  box-shadow: 0 18rpx 40rpx rgba(66, 96, 137, 0.35);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.fab-btn:active {
  transform: scale(0.96);
}

.fab-icon {
  margin-top: -4rpx;
  font-size: 40rpx;
  color: #ffffff;
  font-weight: 400;
}

.fab-text {
  margin-top: -4rpx;
  font-size: 18rpx;
  color: #ffffff;
  font-weight: 700;
}

/* ===== 骨架屏 ===== */
.skeleton-feed {
  display: flex;
  gap: 12rpx;
  padding: 12rpx;
  box-sizing: border-box;
}
.skeleton-col {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}
.skeleton-card {
  border-radius: 28rpx;
  background: var(--surface-container-lowest);
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(44, 51, 56, 0.04);
}
.skeleton-img {
  width: 100%;
  height: 280rpx;
  background: linear-gradient(90deg, var(--surface-container) 25%, var(--surface-container-low) 50%, var(--surface-container) 75%);
  background-size: 220% 100%;
  animation: marketShimmer 1.2s linear infinite;
}
.skeleton-img-tall { height: 360rpx; }
.skeleton-lines {
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}
.skeleton-line {
  height: 20rpx;
  border-radius: 10rpx;
  background: linear-gradient(90deg, var(--surface-container) 25%, var(--surface-container-low) 50%, var(--surface-container) 75%);
  background-size: 220% 100%;
  animation: marketShimmer 1.2s linear infinite;
}
.skeleton-line.w90 { width: 90%; }
.skeleton-line.w80 { width: 80%; }
.skeleton-line.w70 { width: 70%; }
.skeleton-line.w60 { width: 60%; }
.skeleton-line.w50 { width: 50%; }
.skeleton-line.w40 { width: 40%; }

/* ===== 卡片入场动画 ===== */
.goods-card-enter {
  animation: goodsCardIn 0.32s ease both;
}
@keyframes goodsCardIn {
  from { opacity: 0; transform: translateY(30rpx); }
  to   { opacity: 1; transform: translateY(0); }
}
