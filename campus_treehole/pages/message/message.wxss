.page-container {
  padding: 0 28rpx;
}

.msg-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0 18rpx;
}

.msg-header-main {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.msg-title {
  font-size: var(--text-hero);
  font-weight: 800;
  color: var(--on-surface);
  letter-spacing: -1rpx;
}

.msg-subtitle {
  font-size: 22rpx;
  color: var(--outline-variant);
}

.msg-new-btn {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: var(--primary);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: 700;
}

.msg-tabs {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.msg-tab {
  flex: 1;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  height: 88rpx;
  border-radius: var(--radius-md);
  background: var(--surface-container-low);
  color: var(--on-surface-variant);
  font-size: var(--text-body);
  font-weight: 700;
  transition: background 0.2s ease, color 0.2s ease;
}

.msg-tab-active {
  background: var(--primary-container);
  color: var(--on-primary-container);
  box-shadow: inset 0 0 0 2rpx rgba(66, 96, 137, 0.2);
}

.msg-tab-badge {
  min-width: 34rpx;
  height: 34rpx;
  padding: 0 10rpx;
  border-radius: 999rpx;
  background: var(--accent);
  color: #fff;
  font-size: 18rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.load-status {
  padding: 80rpx 0;
  text-align: center;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
  gap: 12rpx;
  text-align: center;
}

.empty-icon {
  font-size: 80rpx;
}

.empty-text {
  font-size: 30rpx;
  color: var(--on-surface-variant);
  font-weight: 600;
}

.empty-sub {
  font-size: 24rpx;
  color: var(--outline-variant);
}

.retry-btn {
  margin-top: 18rpx;
  padding: 18rpx 36rpx;
  border-radius: 999rpx;
  background: var(--primary);
  color: #fff;
  font-size: 26rpx;
  font-weight: 600;
}

.conv-list,
.notice-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.conv-item,
.notice-item {
  position: relative;
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx 20rpx;
  border-radius: 28rpx;
  background: var(--surface-container-lowest);
}

.conv-item-unread,
.notice-item-unread {
  background: var(--surface-container-low);
  box-shadow: inset 0 0 0 2rpx rgba(79, 111, 150, 0.08);
}

.conv-item-unread::before,
.notice-item-unread::before {
  content: '';
  position: absolute;
  left: 0;
  top: 22rpx;
  bottom: 22rpx;
  width: 8rpx;
  border-radius: 999rpx;
  background: var(--primary);
}

.conv-avatar,
.notice-avatar-wrap {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  overflow: visible;
  flex-shrink: 0;
  position: relative;
}

.conv-avatar-unread {
  box-shadow: 0 0 0 4rpx rgba(79, 111, 150, 0.18);
}

.conv-avatar image,
.notice-avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.notice-dot {
  position: absolute;
  right: 0;
  bottom: 4rpx;
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  background: var(--accent);
  box-shadow: 0 0 0 4rpx var(--surface-container-lowest);
}

.conv-info,
.notice-main {
  flex: 1;
  min-width: 0;
}

.conv-top,
.notice-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.conv-name-wrap {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.conv-name {
  min-width: 0;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--on-surface);
}

.conv-name-unread {
  font-weight: 800;
}

.conv-unread-tag,
.conv-latest-tag,
.notice-type-tag {
  flex-shrink: 0;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  font-size: 18rpx;
  font-weight: 700;
}

.conv-unread-tag {
  background: rgba(255, 77, 109, 0.12);
  color: var(--accent);
}

.conv-latest-tag {
  background: rgba(79, 111, 150, 0.12);
  color: var(--primary);
}

.notice-type-tag {
  background: rgba(79, 111, 150, 0.1);
  color: var(--primary);
}

.conv-time,
.notice-time {
  font-size: 22rpx;
  color: var(--outline-variant);
  flex-shrink: 0;
}

.conv-time-unread {
  color: var(--primary);
  font-weight: 700;
}

.conv-bottom {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.conv-last,
.notice-summary,
.notice-content {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.conv-last {
  flex: 1;
  min-width: 0;
  font-size: 26rpx;
  color: var(--outline-variant);
}

.conv-last-unread {
  color: var(--on-surface);
  font-weight: 600;
}

.conv-badge {
  min-width: 36rpx;
  height: 36rpx;
  padding: 0 10rpx;
  border-radius: 999rpx;
  background: var(--error);
  color: #fff;
  font-size: 20rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.notice-summary {
  flex: 1;
  min-width: 0;
  font-size: 28rpx;
  font-weight: 700;
  color: var(--on-surface);
  white-space: normal;
  line-height: 1.45;
}

.notice-content {
  font-size: 24rpx;
  color: var(--on-surface-variant);
  margin-bottom: 10rpx;
}

.notice-meta-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.notice-user-id {
  font-size: 20rpx;
  color: var(--outline-variant);
}

.notice-cover {
  width: 108rpx;
  height: 108rpx;
  border-radius: 22rpx;
  flex-shrink: 0;
  background: var(--surface-container-high);
}

.bottom-placeholder {
  height: 40rpx;
}
