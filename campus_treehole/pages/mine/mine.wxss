.mine-page {
  min-height: 100vh;
  background: #f6f6f6;
}

.mine-cover-wrap {
  position: relative;
  overflow: hidden;
  min-height: 500rpx;
  background: linear-gradient(135deg, #2b2f35 0%, #45525f 45%, #6a7a8a 100%);
}

.mine-cover-bg {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
}

.mine-cover-overlay {
  position: absolute;
  inset: 0;
  z-index: 1;
  background: linear-gradient(to bottom, rgba(0, 0, 0, 0.18) 0%, rgba(0, 0, 0, 0.56) 100%);
}

.top-action-row {
  position: relative;
  z-index: 3;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  padding: 22rpx 24rpx 4rpx;
}

.top-action-ico {
  width: 56rpx;
  height: 56rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.18);
  color: #ffffff;
  font-size: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.top-action-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.top-action-btn {
  height: 56rpx;
  padding: 0 20rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.22);
  color: #ffffff;
  font-size: 24rpx;
  display: flex;
  align-items: center;
}

.profile-section {
  position: relative;
  z-index: 2;
  padding: 16rpx 24rpx 34rpx;
}

.profile-main {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.avatar-wrapper {
  position: relative;
}

.avatar-glow {
  position: absolute;
  inset: -8rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.22);
  filter: blur(14rpx);
}

.profile-avatar {
  position: relative;
  width: 126rpx;
  height: 126rpx;
  border-radius: 50%;
  overflow: hidden;
  border: 4rpx solid rgba(255, 255, 255, 0.95);
}

.profile-avatar image {
  width: 100%;
  height: 100%;
}

.profile-meta {
  flex: 1;
  min-width: 0;
}

.name-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 8rpx;
}

.profile-name {
  max-width: 420rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 46rpx;
  line-height: 1.15;
  font-weight: 800;
  color: #ffffff;
}

.profile-edit {
  color: rgba(255, 255, 255, 0.9);
  font-size: 26rpx;
}

.profile-uid,
.profile-ip {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.88);
  margin-bottom: 6rpx;
}

.profile-uid-copy {
  text-decoration: underline;
  text-decoration-color: rgba(255, 255, 255, 0.65);
}

.profile-bio {
  margin-top: 18rpx;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.94);
  line-height: 1.45;
}

.profile-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 14rpx;
}

.tag-chip {
  padding: 6rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.2);
  color: #ffffff;
  font-size: 22rpx;
}

.page-container {
  margin-top: -22rpx;
  border-radius: 24rpx 24rpx 0 0;
  background: #f6f6f6;
  padding: 22rpx 20rpx 30rpx;
}

.stats-inline {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 18rpx;
  padding: 0 8rpx;
}

.stats-item {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.stats-number {
  font-size: 42rpx;
  font-weight: 800;
  color: #111111;
}

.stats-label {
  font-size: 26rpx;
  color: #555555;
}

.quick-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
  margin-bottom: 20rpx;
}

.quick-card {
  background: #ffffff;
  border-radius: 18rpx;
  padding: 18rpx 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.quick-title {
  display: block;
  font-size: 26rpx;
  font-weight: 700;
  color: #1f1f1f;
  margin-bottom: 6rpx;
}

.quick-sub {
  display: block;
  font-size: 22rpx;
  color: #7a7a7a;
}

.contact-qr-card {
  background: #ffffff;
  border-radius: 18rpx;
  margin-bottom: 18rpx;
  padding: 18rpx 16rpx 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.contact-qr-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #222222;
  margin-bottom: 12rpx;
}

.contact-qr-image {
  width: 100%;
  border-radius: 12rpx;
  background: #f4f6fa;
}

.contact-qr-note {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #5f6773;
  line-height: 1.5;
}

.tab-bar {
  display: flex;
  align-items: center;
  background: #ffffff;
  border-radius: 14rpx;
  padding: 4rpx;
  margin-bottom: 16rpx;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 14rpx 0;
  border-radius: 10rpx;
  font-size: 26rpx;
  color: #777777;
}

.tab-item-active {
  background: #f3f3f3;
  color: #111111;
  font-weight: 700;
}

.post-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  margin-bottom: 24rpx;
}

.wf-grid {
  display: flex;
  gap: 14rpx;
  align-items: flex-start;
}

.wf-col {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.post-card-mini {
  background: #ffffff;
  border-radius: 18rpx;
  padding: 0 0 18rpx;
  box-shadow: 0 4rpx 14rpx rgba(0, 0, 0, 0.04);
  overflow: hidden;
}

.wf-cover {
  display: block;
  width: 100%;
  height: 220rpx;
  background: #f1f3f6;
}

.post-card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 14rpx 16rpx 10rpx;
}

.post-card-nickname {
  font-size: 24rpx;
  font-weight: 600;
  color: #333333;
}

.post-card-time {
  font-size: 22rpx;
  color: #989898;
}

.post-card-content {
  font-size: 28rpx;
  line-height: 1.48;
  color: #232323;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin: 0 16rpx 10rpx;
}

.post-card-footer {
  display: flex;
  gap: 20rpx;
  margin: 0 16rpx;
}

.post-card-stat {
  font-size: 22rpx;
  color: #8d8d8d;
}

.list-load-footer {
  text-align: center;
  padding: 16rpx 0;
  font-size: 24rpx;
  color: #9d9d9d;
}

.expand-row {
  display: flex;
  justify-content: center;
  margin-top: 6rpx;
}

.expand-btn {
  height: 58rpx;
  padding: 0 26rpx;
  border-radius: 999rpx;
  background: #eceef2;
  color: #5d6673;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  padding: 70rpx 0;
  color: #999999;
}

.empty-icon {
  font-size: 72rpx;
}

.empty-text {
  font-size: 26rpx;
}

.menu-section {
  background: #ffffff;
  border-radius: 18rpx;
  padding: 10rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 16rpx;
}

.menu-more-wrap {
  display: flex;
  justify-content: center;
  padding: 8rpx 0 12rpx;
}

.menu-more-btn {
  min-width: 180rpx;
  height: 56rpx;
  border-radius: 999rpx;
  background: #eef2f7;
  color: #58667a;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.menu-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.menu-icon-wrap {
  width: 58rpx;
  height: 58rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.menu-icon-primary { background: rgba(255, 36, 66, 0.1); }
.menu-icon-secondary { background: rgba(66, 96, 137, 0.12); }
.menu-icon-error { background: rgba(210, 47, 47, 0.1); }
.menu-icon-gray { background: rgba(120, 120, 120, 0.1); }

.menu-icon {
  width: 34rpx;
  height: 34rpx;
}

.menu-name {
  font-size: 28rpx;
  color: #222222;
}

.menu-arrow {
  width: 30rpx;
  height: 30rpx;
  opacity: 0.3;
}

.footer-brand {
  text-align: center;
  padding: 26rpx 0 24rpx;
}

.footer-version {
  font-size: 20rpx;
  color: #b0b0b0;
}

.bottom-placeholder {
  height: calc(180rpx + env(safe-area-inset-bottom));
}
