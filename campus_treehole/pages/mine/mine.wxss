/* pages/mine/mine.wxss - 我的页面样式 */
/* 参考 _4 设计：头像光晕、统计卡片、功能菜单列表 */

.mine-page {
  min-height: 100vh;
  background: var(--surface);
}

/* 与 pages/profile 主页封面同源：无图时用学院蓝渐变 */
.mine-cover-wrap {
  position: relative;
  overflow: hidden;
  min-height: 400rpx;
  padding-bottom: 8rpx;
  background: linear-gradient(135deg, #426089 0%, #6a8db5 50%, #8fb3d9 100%);
}

.mine-cover-bg {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
}

.mine-cover-overlay {
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  z-index: 1;
  background: linear-gradient(to bottom, rgba(0, 0, 0, 0.12) 0%, rgba(0, 0, 0, 0.48) 100%);
}

.page-container {
  padding: 24rpx 32rpx;
}

/* ========== 用户头像和信息区域（叠在封面上） ========== */
.profile-section {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 32rpx 40rpx;
}

/* 头像外包裹 */
.avatar-wrapper {
  position: relative;
  margin-bottom: 28rpx;
}

/* 头像光晕效果 */
.avatar-glow {
  position: absolute;
  top: -8rpx;
  left: -8rpx;
  right: -8rpx;
  bottom: -8rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--primary), var(--tertiary-container));
  opacity: 0.2;
  filter: blur(16rpx);
}

.profile-avatar {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  overflow: hidden;
  border: 8rpx solid #ffffff;
  box-shadow: 0 8rpx 28rpx rgba(0, 0, 0, 0.25);
}

.profile-avatar image {
  width: 100%;
  height: 100%;
}

/* 用户昵称（封面区上为浅色字） */
.profile-name {
  font-size: 44rpx;
  font-weight: 800;
  color: #ffffff;
  letter-spacing: -1rpx;
  margin-bottom: 12rpx;
  text-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.35);
}

.profile-uid {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.88);
  margin-bottom: 16rpx;
}

/* 认证徽章 */
.profile-badge {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background-color: rgba(255, 255, 255, 0.22);
  padding: 10rpx 24rpx;
  border-radius: 999rpx;
}

.badge-icon {
  width: 22rpx;
  height: 22rpx;
}

.badge-text {
  font-size: 20rpx;
  font-weight: 700;
  color: rgba(255, 255, 255, 0.95);
}

/* ========== 统计数据卡片 ========== */
.stats-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
  margin-bottom: 40rpx;
}

.stats-card {
  background-color: var(--surface-container-lowest);
  border-radius: 40rpx;
  padding: 32rpx 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  box-shadow: 0 12px 32px rgba(44, 51, 56, 0.06);
}

.stats-number {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--primary);
}

.stats-label {
  font-size: 22rpx;
  font-weight: 500;
  color: var(--on-surface-variant);
  letter-spacing: 2rpx;
}

/* ========== 功能菜单列表 ========== */
.menu-section {
  background-color: rgba(240, 244, 248, 0.5);
  border-radius: 40rpx;
  padding: 12rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-bottom: 48rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx;
  background-color: var(--surface-container-lowest);
  border-radius: 28rpx;
}

.menu-left {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.menu-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 菜单图标背景色变体 */
.menu-icon-primary {
  background-color: rgba(66, 96, 137, 0.1);
}

.menu-icon-error {
  background-color: rgba(168, 56, 54, 0.1);
}

.menu-icon-tertiary {
  background-color: rgba(99, 89, 131, 0.1);
}

.menu-icon-secondary {
  background-color: rgba(85, 96, 113, 0.1);
}

.menu-icon-gray {
  background-color: rgba(171, 179, 185, 0.1);
}

.menu-icon {
  width: 40rpx;
  height: 40rpx;
}

.menu-name {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--on-surface);
}

.menu-arrow {
  width: 32rpx;
  height: 32rpx;
  opacity: 0.3;
}

/* ========== 页脚品牌 ========== */
.footer-brand {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  opacity: 0.4;
  padding: 20rpx 0 40rpx;
}

.footer-title {
  font-size: 20rpx;
  font-weight: 800;
  letter-spacing: 8rpx;
  color: var(--on-surface);
}

.footer-version {
  font-size: 20rpx;
  color: var(--on-surface-variant);
}

/* 底部占位 */
.bottom-placeholder {
  height: 40rpx;
}

/* ========== Tab 切换栏 ========== */
.tab-bar {
  display: flex;
  background-color: var(--surface-container-low);
  border-radius: 999rpx;
  padding: 6rpx;
  margin-bottom: 28rpx;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 26rpx;
  font-weight: 500;
  border-radius: 999rpx;
  color: var(--on-surface-variant);
}

.tab-item-active {
  background-color: var(--surface-container-lowest);
  color: var(--primary);
  font-weight: 700;
  box-shadow: 0 4px 12px rgba(44, 51, 56, 0.06);
}

/* ========== 帖子缩略卡片 ========== */
.post-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.list-load-footer {
  text-align: center;
  padding: 24rpx 0 8rpx;
  font-size: 24rpx;
  color: var(--outline-variant);
}

.post-card-mini {
  padding: 28rpx;
}

.post-card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.post-card-user {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.post-card-nickname {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--on-surface);
}

.post-card-time {
  font-size: 22rpx;
  color: var(--outline-variant);
}

.post-card-content {
  font-size: 28rpx;
  color: var(--on-surface);
  line-height: 1.6;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  margin-bottom: 16rpx;
}

.post-card-footer {
  display: flex;
  gap: 32rpx;
}

.post-card-stat {
  display: flex;
  align-items: center;
  gap: 6rpx;
  font-size: 22rpx;
  color: var(--on-surface-variant);
}

.post-card-icon {
  width: 28rpx;
  height: 28rpx;
  opacity: 0.6;
}

/* ========== 空状态 ========== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
  gap: 16rpx;
}

.empty-icon {
  font-size: 80rpx;
}

.empty-text {
  font-size: 28rpx;
  color: var(--outline-variant);
}

.empty-btn {
  margin-top: 20rpx;
  padding: 16rpx 60rpx;
}

/* ========== 个人资料展示（封面区可读性） ========== */
.profile-bio {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.92);
  margin-top: 16rpx;
  text-align: center;
  padding: 0 40rpx;
  line-height: 1.5;
  text-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.25);
}
.profile-tags { display: flex; flex-wrap: wrap; gap: 12rpx; justify-content: center; margin-top: 16rpx; }
.tag-chip {
  padding: 6rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.22);
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 500;
}
