/* pages/profile/profile.wxss - 用户主页样式 */
.profile-page { background: var(--surface-container-low); min-height: 100vh; }

.profile-denied-full {
  min-height: 70vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
  text-align: center;
}
.profile-denied-icon { font-size: 80rpx; margin-bottom: 24rpx; }
.profile-denied-text {
  font-size: 30rpx;
  color: var(--on-surface-variant);
  line-height: 1.6;
  max-width: 560rpx;
}

/* 封面区域 */
.profile-cover {
  position: relative; height: 360rpx;
  background: linear-gradient(135deg, #426089 0%, #6a8db5 50%, #8fb3d9 100%);
  background-size: cover; background-position: center;
}
.profile-cover-overlay {
  position: absolute; top: 0; left: 0; right: 0; bottom: 0;
  background: linear-gradient(to bottom, rgba(0,0,0,0.1) 0%, rgba(0,0,0,0.4) 100%);
}
.profile-top {
  position: absolute; bottom: 0; left: 0; right: 0;
  display: flex; flex-direction: column; align-items: center;
  padding-bottom: 30rpx; z-index: 2;
}
.profile-avatar-wrap {
  width: 144rpx; height: 144rpx; border-radius: 50%;
  border: 6rpx solid #fff; overflow: hidden; margin-bottom: 12rpx;
  box-shadow: 0 4px 16px rgba(0,0,0,0.2);
}
.profile-avatar-img { width: 100%; height: 100%; }
.profile-nickname { font-size: 36rpx; font-weight: 800; color: #fff; text-shadow: 0 2px 8px rgba(0,0,0,0.3); }
.profile-user-id { font-size: 22rpx; color: rgba(255,255,255,0.88); margin-top: 6rpx; }
.profile-college { font-size: 24rpx; color: rgba(255,255,255,0.8); margin-top: 4rpx; }

/* 自我介绍 */
.profile-bio-section { padding: 24rpx 32rpx 0; }
.profile-bio { font-size: 28rpx; color: var(--on-surface-variant); line-height: 1.6; text-align: center; display: block; }

/* 兴趣标签 */
.profile-tags {
  display: flex; flex-wrap: wrap; gap: 12rpx;
  padding: 20rpx 32rpx; justify-content: center;
}
.tag-item {
  padding: 8rpx 24rpx; border-radius: 999rpx; font-size: 24rpx;
  background: var(--primary-container); color: var(--on-primary-container);
}

/* 统计数据 */
.profile-stats {
  display: flex; align-items: center; justify-content: center;
  padding: 28rpx 24rpx; gap: 0;
}
.profile-stats-four .stat-num { font-size: 32rpx; }
.profile-stats-four .stat-label { font-size: 22rpx; }
.stat-item { flex: 1; text-align: center; display: flex; flex-direction: column; gap: 4rpx; min-width: 0; }
.stat-num { font-size: 36rpx; font-weight: 800; color: var(--on-surface); }
.stat-label { font-size: 24rpx; color: var(--outline-variant); }
.stat-divider { width: 1rpx; height: 48rpx; background: var(--outline-variant); opacity: 0.3; flex-shrink: 0; }

/* 操作按钮 */
.profile-actions { display: flex; flex-wrap: wrap; gap: 20rpx; padding: 0 32rpx 24rpx; }
.action-follow-btn {
  flex: 1; min-width: 200rpx; text-align: center; padding: 18rpx 0; border-radius: 999rpx;
  background: var(--primary); color: #fff; font-size: 28rpx; font-weight: 600;
}
.action-follow-btn.followed { background: var(--surface-container-low); color: var(--on-surface-variant); border: 2rpx solid var(--outline-variant); }
.action-msg-btn {
  flex: 1; min-width: 200rpx; text-align: center; padding: 18rpx 0; border-radius: 999rpx;
  background: var(--surface-container-lowest); color: var(--on-surface); font-size: 28rpx; font-weight: 600;
  border: 2rpx solid var(--outline-variant);
}
.action-block-btn {
  flex: 1; min-width: 200rpx; text-align: center; padding: 18rpx 0; border-radius: 999rpx;
  background: var(--surface-container-lowest); color: var(--on-surface-variant); font-size: 28rpx; font-weight: 600;
  border: 2rpx solid var(--outline-variant);
}
.action-block-btn-active {
  border-color: var(--primary);
  color: var(--primary);
}
.action-ban-btn {
  flex: 0 0 auto; text-align: center; padding: 18rpx 32rpx; border-radius: 999rpx;
  background: var(--error); color: #fff; font-size: 28rpx; font-weight: 600;
  white-space: nowrap;
}

/* 动态 / 闲置 切换 */
.profile-segment {
  display: flex;
  margin: 8rpx 32rpx 20rpx;
  padding: 6rpx;
  background: var(--surface-container-high);
  border-radius: 999rpx;
  gap: 8rpx;
}
.seg-item {
  flex: 1;
  text-align: center;
  padding: 18rpx 12rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--on-surface-variant);
  border-radius: 999rpx;
}
.seg-active {
  background: var(--surface-container-lowest);
  color: var(--primary);
  box-shadow: 0 4rpx 12rpx rgba(44, 51, 56, 0.08);
}

.profile-list-wrap { padding: 0 32rpx 40rpx; display: flex; flex-direction: column; gap: 16rpx; }

.post-card-mini {
  display: flex;
  gap: 20rpx;
  background: var(--surface-container-lowest);
  border-radius: var(--radius-m);
  padding: 20rpx;
  align-items: stretch;
}
.post-card-thumb {
  width: 176rpx;
  height: 176rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
  background: var(--surface-container-low);
}
.post-card-main { flex: 1; min-width: 0; display: flex; flex-direction: column; }
.post-card-content {
  font-size: 28rpx; color: var(--on-surface); line-height: 1.55;
  overflow: hidden; text-overflow: ellipsis; display: -webkit-box;
  -webkit-line-clamp: 4; -webkit-box-orient: vertical;
  margin-bottom: 12rpx;
}
.post-card-footer { display: flex; gap: 24rpx; align-items: center; margin-top: auto; }
.post-card-stat { font-size: 24rpx; color: var(--on-surface-variant); }
.post-card-time { font-size: 22rpx; color: var(--outline-variant); margin-left: auto; }

/* 闲置卡片 */
.goods-card-mini {
  display: flex;
  gap: 20rpx;
  background: var(--surface-container-lowest);
  border-radius: var(--radius-m);
  padding: 20rpx;
  align-items: stretch;
}
.goods-card-thumb {
  width: 176rpx;
  height: 176rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
  background: var(--surface-container-low);
}
.goods-card-thumb-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
}
.goods-card-main { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 8rpx; }
.goods-card-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--on-surface);
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}
.goods-card-price {
  font-size: 32rpx;
  font-weight: 800;
  color: var(--accent);
}
.goods-card-time {
  font-size: 22rpx;
  color: var(--outline-variant);
  margin-top: auto;
}

.profile-list-footer {
  text-align: center;
  padding: 20rpx 0 8rpx;
  font-size: 24rpx;
  color: var(--outline-variant);
}

/* 空状态 */
.empty-state { display: flex; flex-direction: column; align-items: center; padding: 60rpx 0; gap: 12rpx; }
.empty-icon { font-size: 60rpx; }
.empty-text { font-size: 28rpx; color: var(--outline-variant); }
