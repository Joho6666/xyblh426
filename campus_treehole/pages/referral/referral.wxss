.page {
  min-height: 100vh;
  padding: 24rpx;
  padding-bottom: 48rpx;
  background: #f7f9fc;
  box-sizing: border-box;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(66, 96, 137, 0.08);
}

.intro-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 12rpx;
}

.intro-desc {
  display: block;
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
  margin-bottom: 20rpx;
}

.ref-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  font-size: 26rpx;
  padding: 10rpx 0;
  border-top: 1rpx solid #eee;
}

.ref-row .k {
  color: #888;
  flex-shrink: 0;
  margin-right: 16rpx;
}

.ref-row .v {
  color: #333;
  text-align: right;
  word-break: break-all;
}

.mono {
  font-family: ui-monospace, monospace;
}

.path {
  font-size: 22rpx;
}

.stats {
  display: flex;
  justify-content: space-around;
  text-align: center;
}

.stat .num {
  display: block;
  font-size: 44rpx;
  font-weight: 600;
  color: #426089;
}

.stat .lbl {
  font-size: 24rpx;
  color: #888;
}

.section-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.qr-wrap {
  text-align: center;
}

.qr {
  width: 320rpx;
  height: 320rpx;
  background: #fafafa;
}

.muted {
  font-size: 26rpx;
  color: #999;
  line-height: 1.5;
}

.btn-primary {
  margin: 8rpx 0 24rpx;
  background: #426089;
  color: #fff;
}

.hint {
  font-size: 24rpx;
  color: #888;
  line-height: 1.5;
  padding: 0 8rpx;
}
